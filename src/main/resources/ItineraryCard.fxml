<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="cardContainer" spacing="8" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 16;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.ItineraryCardController">

    <!-- En-tête avec les boutons -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <!-- Icône -->
        <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48;">
            <Label fx:id="iconLabel" style="-fx-font-size: 24;" text="🗺️" />
        </VBox>

        <!-- Titre et destination -->
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="nameLabel" style="-fx-font-weight: 700; -fx-text-fill: #0f172a; -fx-font-size: 16;" />

            <HBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label style="-fx-font-size: 10;" text="📍" />
                    <Label fx:id="destLabel" style="-fx-text-fill: #64748b; -fx-font-size: 11;" />
                </HBox>
            </HBox>
        </VBox>

        <!-- Boutons d'action -->
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <!-- NOUVEAU: Bouton d'export -->
            <Button fx:id="exportButton" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 10; -fx-font-size: 12; -fx-cursor: hand;" text="📤">
                <tooltip>
                    <Tooltip text="Exporter" />
                </tooltip>
            </Button>

            <Button fx:id="editButton" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 6 10; -fx-font-size: 12; -fx-cursor: hand;" text="✏️">
                <tooltip>
                    <Tooltip text="Modifier" />
                </tooltip>
            </Button>

            <Button fx:id="deleteButton" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-background-radius: 8; -fx-padding: 6 10; -fx-font-size: 12; -fx-cursor: hand;" text="🗑️">
                <tooltip>
                    <Tooltip text="Supprimer" />
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <!-- Description -->
    <Label fx:id="descLabel" style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-padding: 0 0 4 0;" wrapText="true" />

    <!-- Séparateur -->
    <Separator style="-fx-background-color: #e2e8f0;" />

    <!-- Jours du voyage (CERCLES CLIQUABLES) -->
    <VBox spacing="4" style="-fx-padding: 8 0 0 0;">
        <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 11; -fx-padding: 0 0 4 0;" text="Jours du voyage :" />

        <!-- Conteneur principal pour les jours -->
        <VBox fx:id="joursContainer" spacing="10">
            <!-- Message si pas de jours -->
            <Label fx:id="pasJoursLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 10; -fx-font-style: italic;" text="Dates non définies" />
        </VBox>
    </VBox>
</VBox>