<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DestinationFrontController">

    <!-- TOP NAV - STYLE CLAIR AVEC ORANGE -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="20" left="32" right="32" top="20" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU - EXPANDED WITH ALL BUTTONS -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 0 20;">
                    <!-- Destinations - Active -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,140,66,0.1); -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 16;" text="🌍" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14;" text="Destinations" />
                    </HBox>

                    <!-- Hébergement -->
                    <HBox fx:id="btnHebergement" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🏨" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergement" />
                    </HBox>

                    <!-- Itinéraires -->
                    <HBox fx:id="btnItineraires" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🗺️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Itinéraires" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="✈️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- SEARCH BAR REMOVED -->

                <!-- Notifications (kept) -->
                <HBox alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🔔" />
                </HBox>

                <!-- User Profile (kept) -->
                <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #f1f5f9; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <VBox spacing="0">
                        <Label style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 13;" text="Neyrouz Chekir" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Administrateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 12 32;">
                <!-- Home Button -->
                <HBox fx:id="btnHome" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="🏠" />
                </HBox>
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Destinations" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 12; -fx-font-weight: 600;" text="Gestion des destinations" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- ICON-ONLY QUICK ACTION BUTTONS - EXPORT REMOVED, ONLY REFRESH KEPT -->
                <HBox spacing="8">
                    <!-- Refresh Button (kept) -->
                    <HBox fx:id="btnRefresh" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="🔄" />
                    </HBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- BOTTOM STATUS (unchanged) -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 12 32;">
            <Label style="-fx-text-fill: #10b981; -fx-font-size: 11; -fx-font-weight: 500;" text="● Connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: 12 Fév 2026, 15:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT (unchanged) -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox maxWidth="1400" spacing="32">
                    <padding>
                        <Insets bottom="60" left="40" right="40" top="40" />
                    </padding>

                    <!-- HEADER SECTION - STATS GLOBALES -->
                    <HBox alignment="CENTER_LEFT" spacing="24">
                        <!-- Icon -->
                        <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 24; -fx-min-width: 80; -fx-min-height: 80;">
                            <Label style="-fx-font-size: 48;" text="🌍" />
                        </VBox>

                        <!-- Stats Info -->
                        <VBox spacing="8" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Destinations" />
                                <Label fx:id="lblStatut" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 12; -fx-font-size: 11; -fx-font-weight: 600;" text="● 12 destinations" />
                            </HBox>

                            <HBox spacing="24">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 14;" text="🌡️" />
                                    <Label fx:id="lblClimatDiversite" style="-fx-text-fill: #475569; -fx-font-size: 14;" text="5 climats différents" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 14;" text="🗓️" />
                                    <Label fx:id="lblSaisons" style="-fx-text-fill: #475569; -fx-font-size: 14;" text="Toutes saisons" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 14;" text="📍" />
                                    <Label fx:id="lblPaysCount" style="-fx-text-fill: #475569; -fx-font-size: 14;" text="8 pays représentés" />
                                </HBox>
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Quick Actions -->
                        <VBox alignment="CENTER_RIGHT" spacing="8">
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Gestionnaire de destinations" />
                        </VBox>
                    </HBox>

                    <!-- KPI CARDS - STATS DESTINATIONS -->
                    <HBox spacing="20">
                        <!-- Total Destinations Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2); -fx-border-color: #ff8c42; -fx-border-width: 0 0 0 4; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🗺️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="TOTAL DESTINATIONS" />
                                    <Label fx:id="lblTotalDestinations" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="0" />
                                </VBox>
                            </HBox>
                            <Label fx:id="lblTotalPays" style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Chargement..." />
                        </VBox>

                        <!-- Destinations Actives Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #e6f7e6; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="✅" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="ACTIVES" />
                                    <Label fx:id="lblDestinationsActives" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0" />
                                </VBox>
                            </HBox>
                            <Label fx:id="lblActivesPourcentage" style="-fx-text-fill: #10b981; -fx-font-size: 12; -fx-font-weight: 500;" text="0% des destinations" />
                        </VBox>

                        <!-- Couverture Climatique Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #fef2f2; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🌡️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="CLIMATS" />
                                    <Label fx:id="lblClimatsCount" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Types de climats disponibles" />
                        </VBox>

                        <!-- Saisons Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🗓️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="SAISONS" />
                                    <Label fx:id="lblSaisonsCount" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #ff8c42;" text="0" />
                                </VBox>
                            </HBox>
                            <ProgressBar fx:id="progressSaisons" prefWidth="200" progress="0" style="-fx-accent: #ff8c42; -fx-background-color: #e2e8f0;" />
                        </VBox>
                    </HBox>

                    <!-- TABLEAU DES DESTINATIONS - DYNAMIC HEIGHT -->
                    <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 28; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                        <!-- Table Header -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Liste des Destinations" />
                            <Label fx:id="lblDestinationCount" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 12; -fx-font-weight: 600; -fx-font-size: 11;" text="0 destinations" />
                            <Region HBox.hgrow="ALWAYS" />

                            <!-- Only Search and Filter buttons -->
                            <HBox spacing="8">
                                <HBox fx:id="btnSearch" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                                    <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="🔍" />
                                </HBox>
                                <HBox fx:id="btnFilter" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                                    <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="📊" />
                                </HBox>
                            </HBox>
                        </HBox>

                        <!-- TABLE -->
                        <TableView fx:id="tableDestinations" style="-fx-background-color: transparent; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNom" text="Nom" />
                                <TableColumn fx:id="colPays" text="Pays" />
                                <TableColumn fx:id="colDescription" text="Description" />
                                <TableColumn fx:id="colClimat" text="Climat" />
                                <TableColumn fx:id="colSaison" text="Saison idéale" />
                                <TableColumn fx:id="colActions" text="Consulter" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="12">
                                    <Label style="-fx-font-size: 32;" text="🗺️" />
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 14;" text="Aucune destination à afficher" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="8" arcWidth="8" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" width="1400">
                        <VBox.margin>
                            <Insets top="20" />
                        </VBox.margin>
                    </Rectangle>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>