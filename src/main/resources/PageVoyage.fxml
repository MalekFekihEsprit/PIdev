<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="750" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.VoyageController">

    <!-- TOP NAV - STYLE CLAIR AVEC ORANGE -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="15" left="20" right="20" top="15" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="8">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="14" />
                    <Label style="-fx-font-family: 'System'; -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 8; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU -->
                <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0 0 0 15;">
                    <!-- Destinations -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Itinéraires -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🗺️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Itinéraires" />
                    </HBox>

                    <!-- Activités -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Voyages - Active -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(255,140,66,0.1); -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14;" text="✈️" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search bar -->
                <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 16;">
                    <Label style="-fx-font-size: 12;" text="🔍" />
                </HBox>

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 35; -fx-min-height: 35; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 14;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-background-radius: 25; -fx-padding: 4 12 4 4; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="14" />
                    <VBox spacing="0">
                        <Label prefHeight="17" prefWidth="90" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Minyar GHANNEM" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 8 20;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 600;" text="Voyages" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Tous les voyages" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Filtres rapides -->
                <HBox spacing="8">
                    <Label style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 20; -fx-padding: 3 10; -fx-font-size: 10; -fx-cursor: hand;" text="📅 Tous" />
                    <Label style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 20; -fx-padding: 3 10; -fx-font-size: 10; -fx-cursor: hand;" text="✅ À venir" />
                    <Label style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 20; -fx-padding: 3 10; -fx-font-size: 10; -fx-cursor: hand;" text="🟡 En cours" />
                    <Label style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 20; -fx-padding: 3 10; -fx-font-size: 10; -fx-cursor: hand;" text="✅ Terminé" />
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 20;">
            <Label style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 500;" text="● Connecté" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="5 voyages actifs" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Dernière mise à jour: 12 Fév 2026, 15:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT - STYLE CLAIR -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox maxWidth="1100" spacing="24">
                    <padding>
                        <Insets bottom="40" left="30" right="30" top="30" />
                    </padding>

                    <!-- FILTRES ET RECHERCHE AVANCÉE -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">

                        <!-- LIGNE DES BOUTONS D'ACTION -->
                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <!-- Bouton Annuler (caché par défaut) -->
                            <Button fx:id="btnAnnulerModification"
                                    onAction="#annulerModification"
                                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none;"
                                    text="Annuler"
                                    visible="false"
                                    managed="false" />

                            <!-- Bouton Ajouter (visible par défaut) -->
                            <Button fx:id="btnAjouter"
                                    mnemonicParsing="false"
                                    onAction="#saveVoyage"
                                    style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none;"
                                    text="Ajouter Voyage"
                                    visible="true"
                                    managed="true" />

                            <!-- BOUTON MODIFIER FORMULAIRE (caché par défaut) -->
                            <Button fx:id="btnModifierFormulaire"
                                    onAction="#ouvrirFormulaireModification"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none;"
                                    text="✏️ Modifier un voyage"
                                    visible="false"
                                    managed="false" />

                            <!-- Bouton Confirmer Modification (caché par défaut) -->
                            <Button fx:id="btnConfirmerModification"
                                    onAction="#confirmerModification"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none;"
                                    text="✓ Confirmer modification"
                                    visible="false"
                                    managed="false" />
                        </HBox>

                        <!-- Grille des champs de formulaire -->
                        <GridPane hgap="15" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>

                            <!-- Titre et Destination -->
                            <VBox spacing="4" GridPane.columnIndex="0">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="Titre" />
                                <TextField fx:id="fxtitre" promptText="titre" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-border-color: transparent;" />
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="ID Destination" />
                                <TextField fx:id="fxdestination" promptText="ID destination" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-border-color: transparent;" />
                            </VBox>

                            <!-- Date début -->
                            <VBox spacing="4" GridPane.columnIndex="1">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="Date début" />
                                <DatePicker fx:id="fxdated" promptText="JJ/MM/AAAA"
                                            style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-border-color: transparent;"
                                            editable="false" />
                            </VBox>

                            <!-- Date fin -->
                            <VBox spacing="4" GridPane.columnIndex="2">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="Date fin" />
                                <DatePicker fx:id="fxdatef" promptText="JJ/MM/AAAA"
                                            style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-border-color: transparent;"
                                            editable="false" />
                            </VBox>

                            <!-- Statut -->
                            <VBox spacing="4" GridPane.columnIndex="3">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="Statut" />
                                <ComboBox fx:id="fxstatut" prefWidth="120" promptText="Sélectionner" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="À venir" />
                                            <String fx:value="En cours" />
                                            <String fx:value="Terminé" />
                                            <String fx:value="Annulé" />
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- ============ LISTE DES VOYAGES - MES VOYAGES ============ -->
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-family: 'System'; -fx-font-size: 20; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Mes voyages" />
                            <Label fx:id="lblVoyagesCount" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 3 10; -fx-font-weight: 600; -fx-font-size: 10;" text="0 voyages" />
                            <Region HBox.hgrow="ALWAYS" />
                        </HBox>

                        <!-- Conteneur dynamique pour les voyages -->
                        <VBox fx:id="voyagesContainer" spacing="12">
                            <!-- Les cartes de voyages seront ajoutées dynamiquement via le contrôleur -->
                        </VBox>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" width="1100">
                        <VBox.margin>
                            <Insets top="15" />
                        </VBox.margin>
                    </Rectangle>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>