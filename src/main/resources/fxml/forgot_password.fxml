<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ForgotPasswordController">

    <VBox alignment="CENTER" spacing="24" style="-fx-background-color: white; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 8); -fx-max-width: 480; -fx-padding: 40;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <!-- Logo -->
        <HBox alignment="CENTER" spacing="10">
            <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="24" />
            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
            <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
        </HBox>

        <!-- Title -->
        <Label style="-fx-font-size: 24; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Mot de passe oublié" />

        <!-- Description -->
        <Label style="-fx-font-size: 14; -fx-text-fill: #64748b; -fx-wrap-text: true; -fx-text-alignment: center;" text="Saisissez votre adresse e-mail. Nous vous enverrons un lien pour réinitialiser votre mot de passe." />

        <!-- Email -->
        <VBox spacing="8">
            <Label style="-fx-font-size: 14; -fx-font-weight: 500; -fx-text-fill: #475569;" text="Email" />
            <TextField fx:id="emailField" promptText="exemple@email.com" style="-fx-background-color: #f1f5f9; -fx-background-radius: 16; -fx-padding: 14 18; -fx-font-size: 14; -fx-border-color: transparent; -fx-border-width: 2;" />
        </VBox>

        <!-- Send button -->
        <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSend" prefHeight="48" style="-fx-background-color: #ff8c42; -fx-background-radius: 24; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Envoyer" />

        <!-- Back to login -->
        <Hyperlink fx:id="backToLoginLink" onAction="#goToLogin" style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14; -fx-border-color: transparent;" text="Retour à la connexion" />
    </VBox>
</AnchorPane>