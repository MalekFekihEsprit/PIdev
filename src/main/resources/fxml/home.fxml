<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.HomeController">
<VBox alignment="CENTER" spacing="30" style="-fx-background-color: white; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 8); -fx-max-width: 600; -fx-padding: 50;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="48" />
    <Label fx:id="welcomeLabel" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Bienvenue !" />
    <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="Vous êtes connecté à TravelMate." />
     
    <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="Accédez à votre profil pour gérer vos informations et préférences." />
    <Button mnemonicParsing="false" onAction="#goToProfile" prefHeight="48" prefWidth="200" style="-fx-background-color: #3b82f6; -fx-background-radius: 24; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Mon Profil" />

    <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="48" prefWidth="200" style="-fx-background-color: #ff8c42; -fx-background-radius: 24; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Déconnexion" />
</VBox>
</AnchorPane>
