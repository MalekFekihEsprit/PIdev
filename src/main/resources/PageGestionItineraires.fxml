<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="800" prefWidth="1200" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.GestionItinerairesController">

    <!-- SIDEBAR - MENU ADMINISTRATION (plus compacte) -->
    <left>
        <VBox prefWidth="240" spacing="6" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="20" />
            </padding>

            <!-- Logo compact -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 15 0;">
                <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 2 6; -fx-font-size: 9; -fx-font-weight: bold;" text="ADMIN" />
            </HBox>

            <!-- MENU PRINCIPAL compact -->
            <Label style="-fx-font-size: 11; -fx-font-weight: 700; -fx-text-fill: #64748b; -fx-letter-spacing: 1;" text="MENU" />

            <VBox spacing="3" style="-fx-padding: 8 0 15 0;">
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 10; -fx-padding: 8 12; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 10;">
                    <Label style="-fx-font-size: 16;" text="📊" />
                    <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 13;" text="Dashboard" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 10; -fx-padding: 8 12; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🗺️" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 13;" text="Itinéraires" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 10; -fx-padding: 8 12; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="📅" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 13;" text="Étapes" />
                </HBox>
            </VBox>

            <Rectangle fill="#1e2749" height="1" width="200">
                <VBox.margin>
                    <Insets bottom="15" top="5" />
                </VBox.margin>
            </Rectangle>

            <!-- STATISTIQUES compactes -->
            <Label style="-fx-font-size: 11; -fx-font-weight: 700; -fx-text-fill: #64748b; -fx-letter-spacing: 1;" text="STATS" />

            <VBox spacing="10" style="-fx-background-color: #0a0e27; -fx-background-radius: 12; -fx-padding: 12;">
                <GridPane hgap="8" vgap="8">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Itinéraires:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="statsTotalItineraires" style="-fx-font-weight: bold; -fx-text-fill: #ff8c42; -fx-font-size: 14;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Étapes:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="statsTotalEtapes" style="-fx-font-weight: bold; -fx-text-fill: #34d399; -fx-font-size: 14;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Destinations:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="statsTotalDestinations" style="-fx-font-weight: bold; -fx-text-fill: #f87171; -fx-font-size: 14;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                </GridPane>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- BOUTON RETOUR compact -->
            <Button onAction="#handleRetourVersItineraire"
                    style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 10; -fx-font-size: 12;"
                    text="← Retour" />
        </VBox>
    </left>

    <!-- MAIN CONTENT (plus compact) -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent;">
            <content>
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="30" left="25" right="25" top="25" />
                    </padding>

                    <!-- HEADER compact -->
                    <VBox spacing="4">
                        <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Gestion des Itinéraires" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Administration complète" />
                    </VBox>

                    <!-- KPI CARDS compacts -->
                    <HBox spacing="12">
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 10; -fx-min-width: 35; -fx-min-height: 35;">
                                    <Label style="-fx-font-size: 16;" text="🗺️" />
                                </VBox>
                                <VBox spacing="1">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10; -fx-font-weight: 500;" text="ITINÉRAIRES" />
                                    <Label fx:id="kpiItineraires" style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #34d399; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(52,211,153,0.15); -fx-background-radius: 10; -fx-min-width: 35; -fx-min-height: 35;">
                                    <Label style="-fx-font-size: 16;" text="📅" />
                                </VBox>
                                <VBox spacing="1">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10; -fx-font-weight: 500;" text="ÉTAPES" />
                                    <Label fx:id="kpiEtapes" style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #34d399;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #f87171; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(248,113,113,0.15); -fx-background-radius: 10; -fx-min-width: 35; -fx-min-height: 35;">
                                    <Label style="-fx-font-size: 16;" text="🌍" />
                                </VBox>
                                <VBox spacing="1">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10; -fx-font-weight: 500;" text="DESTINATIONS" />
                                    <Label fx:id="kpiDestinations" style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #f87171;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- BARRE D'ACTIONS compacte -->
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #111633; -fx-background-radius: 10; -fx-padding: 10 15;">
                        <Button fx:id="btnNouvelItineraire" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 11;" text="➕ Itinéraire">
                            <tooltip><Tooltip text="Créer un nouvel itinéraire" /></tooltip>
                        </Button>
                        <Button fx:id="btnNouvelleEtape" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 11;" text="➕ Étape">
                            <tooltip><Tooltip text="Ajouter une nouvelle étape" /></tooltip>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #1e2749; -fx-background-radius: 16; -fx-padding: 4 12;">
                            <Label style="-fx-font-size: 12;" text="🔍" />
                            <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-pref-width: 160; -fx-font-size: 11;" />
                        </HBox>
                    </HBox>

                    <!-- FILTRES compacts - Correction : retrait de wrapText -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11; -fx-font-weight: 600;" text="Filtres :" />
                        <ComboBox fx:id="comboDestination" promptText="Destination" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 11;" prefWidth="140" />
                        <DatePicker fx:id="dateDebut" promptText="Début" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 6; -fx-font-size: 11;" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="→" />
                        <DatePicker fx:id="dateFin" promptText="Fin" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 6; -fx-font-size: 11;" />
                        <Button fx:id="btnFiltrer" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 11;" text="Appliquer" />
                        <Button fx:id="btnReinitialiser" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 11;" text="Réinit" />
                    </HBox>

                    <!-- TAB PANE avec tables plus petites -->
                    <TabPane style="-fx-background-color: #111633; -fx-background-radius: 12; -fx-tab-min-height: 35;" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab closable="false" text="Itinéraires">
                                <content>
                                    <VBox spacing="10" style="-fx-padding: 15;">
                                        <TableView fx:id="tableItineraires" style="-fx-background-color: #1e2749; -fx-background-radius: 10;" VBox.vgrow="ALWAYS" prefHeight="300">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                                                <TableColumn fx:id="colNom" prefWidth="130" text="Nom" />
                                                <TableColumn fx:id="colDescription" prefWidth="200" text="Description" />
                                                <TableColumn fx:id="colVoyage" prefWidth="120" text="Voyage" />
                                                <TableColumn fx:id="colDestination" prefWidth="120" text="Destination" />
                                                <TableColumn fx:id="colNbEtapes" prefWidth="70" text="Étapes" />
                                                <TableColumn fx:id="colActions" prefWidth="100" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </content>
                            </Tab>
                            <Tab closable="false" text="Étapes">
                                <content>
                                    <VBox spacing="10" style="-fx-padding: 15;">
                                        <TableView fx:id="tableEtapes" style="-fx-background-color: #1e2749; -fx-background-radius: 10;" VBox.vgrow="ALWAYS" prefHeight="300">
                                            <columns>
                                                <TableColumn fx:id="colEtapeId" prefWidth="50" text="ID" />
                                                <TableColumn fx:id="colEtapeHeure" prefWidth="70" text="Heure" />
                                                <TableColumn fx:id="colEtapeDescription" prefWidth="180" text="Description" />
                                                <TableColumn fx:id="colEtapeActivite" prefWidth="130" text="Activité" />
                                                <TableColumn fx:id="colEtapeItineraire" prefWidth="130" text="Itinéraire" />
                                                <TableColumn fx:id="colEtapeLieu" prefWidth="100" text="Lieu" />
                                                <TableColumn fx:id="colEtapeDuree" prefWidth="70" text="Durée" />
                                                <TableColumn fx:id="colEtapeActions" prefWidth="100" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </content>
                            </Tab>
                        </tabs>
                    </TabPane>

                    <!-- FOOTER DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>