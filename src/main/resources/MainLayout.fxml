<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.MainLayoutController"
            prefHeight="720"
            style="-fx-background-color: #f8fafc;">

    <!-- NAVBAR -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="15" left="24" right="24" top="15" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="8">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="12" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 8; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU -->
                <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0 0 0 15;">
                    <!-- Destinations -->
                    <HBox fx:id="navDestinations" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;" onMouseClicked="#handleNavigation">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Itinéraires -->
                    <HBox fx:id="navItineraires" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;" onMouseClicked="#handleNavigation">
                        <Label style="-fx-font-size: 14;" text="🗺" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Itinéraires" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="navActivites" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;" onMouseClicked="#handleNavigation">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="navVoyages" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;" onMouseClicked="#handleNavigation">
                        <Label style="-fx-font-size: 14;" text="✈" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="navBudgets" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;" onMouseClicked="#handleNavigation">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search bar -->
                <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 16; -fx-padding: 6 16;">
                    <Label style="-fx-font-size: 12;" text="🔍" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Rechercher un itinéraire..." />
                </HBox>

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 32; -fx-min-height: 32; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 14;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 4 12 4 4; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="12" />
                    <VBox spacing="0">
                        <Label style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Meriem Bou" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 8;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 8 24;">
                <Label fx:id="breadcrumbAccueil" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="🏠 Accueil" onMouseClicked="#handleNavigation" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="›" />
                <Label fx:id="breadcrumbCurrent" style="-fx-text-fill: #ff8c42; -fx-font-size: 10; -fx-font-weight: 600;" text="Itinéraires" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" />
            </HBox>
        </VBox>
    </top>

    <!-- CONTENU DYNAMIQUE (LES PAGES SERONT CHARGÉES ICI) -->
    <center>
        <StackPane fx:id="contentArea" />
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 24;">
            <Label style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 500;" text="● Connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Dernière mise à jour: 13 Fév 2026, 10:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>
</BorderPane>