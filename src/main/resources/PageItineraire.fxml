<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<?import javafx.scene.control.ComboBox?>
<BorderPane fx:id="mainBorderPane" prefHeight="720" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.PageItineraire">

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30" left="24" right="24" top="24" />
                    </padding>

                    <!-- HEADER SECTION -->
                    <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                        <!-- Icon -->
                        <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 18; -fx-min-width: 60; -fx-min-height: 60;">
                            <Label style="-fx-font-size: 36;" text="🗺" />
                        </VBox>

                        <!-- Stats Info -->
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Mes Itinéraires" />
                                <Label fx:id="lblTotalItinerairesTable" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 2 8; -fx-font-size: 9; -fx-font-weight: 600;" text="0 itinéraire" />
                            </HBox>

                            <HBox spacing="16">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label style="-fx-font-size: 12;" text="✈" />
                                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12;" text="8 destinations" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label style="-fx-font-size: 12;" text="📅" />
                                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12;" text="42 jours d'aventure" />
                                </HBox>
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Quick Actions -->
                        <VBox alignment="CENTER_RIGHT" spacing="6">
                            <HBox spacing="6">
                                <Label onMouseClicked="#handleCreerClick" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 11; -fx-cursor: hand;" text="➕ Créer" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- FILTERS SECTION -->
                    <VBox spacing="10" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Filtres" />

                            <ComboBox fx:id="comboDestination" promptText="Toutes les destinations" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 2;" HBox.hgrow="ALWAYS" />

                            <DatePicker fx:id="dateDebut" promptText="Date début" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10;" HBox.hgrow="ALWAYS" />

                            <Label style="-fx-font-size: 14px; -fx-text-fill: #94a3b8;" text="→" />

                            <DatePicker fx:id="dateFin" promptText="Date fin" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10;" HBox.hgrow="ALWAYS" />

                            <Button fx:id="btnRechercher" onAction="#handleRechercherClick" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 6 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Rechercher" />
                        </HBox>
                    </VBox>

                    <!-- LISTE DES ITINÉRAIRES -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Liste des itinéraires" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="6">
                                <Label onMouseClicked="#handleTrierParDate" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 16; -fx-padding: 4 10; -fx-font-size: 10; -fx-cursor: hand;" text="📅 Trier par date" />
                                <Label onMouseClicked="#handleExporter" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 16; -fx-padding: 4 10; -fx-font-size: 10; -fx-cursor: hand;" text="📊 Exporter" />
                            </HBox>
                        </HBox>

                        <!-- ITINERARY CARDS CONTAINER -->
                        <VBox fx:id="itinerariesContainer" spacing="15" VBox.vgrow="ALWAYS">
                            <!-- Les cartes seront générées dynamiquement -->
                        </VBox>

                        <!-- Message si aucun itinéraire -->
                        <VBox fx:id="emptyPlaceholder" alignment="CENTER" managed="false" spacing="8" visible="false">
                            <Label style="-fx-font-size: 24;" text="🗺️" />
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Aucun itinéraire à afficher" />
                            <Button fx:id="btnCreerPremierItineraire" onAction="#handleCreerClick" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 16; -fx-padding: 6 12; -fx-cursor: hand;" text="+ Créer votre premier itinéraire" />
                        </VBox>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" VBox.vgrow="NEVER" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>