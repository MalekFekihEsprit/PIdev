<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500" prefWidth="500" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.DestinationDeleteReasonController">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10" prefHeight="30" vgrow="SOMETIMES" />
    </rowConstraints>
    <children>
        <VBox spacing="20" style="-fx-background-color: #111633; -fx-background-radius: 20; -fx-padding: 24;">
            <padding>
                <Insets bottom="24" left="24" right="24" top="24" />
            </padding>

            <!-- Header -->
            <VBox spacing="8">
                <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #ff8c42;" text="🗑️ Confirmation de suppression" />
                <Label fx:id="lblWarning" style="-fx-text-fill: #f87171; -fx-font-size: 12;" text="⚠️ Cette action est irréversible" />
                <Label fx:id="lblItemInfo" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" wrapText="true" />
            </VBox>

            <!-- Creator Info -->
            <VBox spacing="8" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-padding: 16;">
                <Label style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #ff8c42;" text="Créé par :" />
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size: 16;" text="👤" />
                    <Label fx:id="lblCreatorName" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: 600;" text="..." />
                </HBox>
                <Label fx:id="lblNote" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Vous êtes sur le point de supprimer une destination créée par un autre utilisateur" />
            </VBox>

            <!-- Reason Selection -->
            <VBox spacing="12">
                <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: 600;" text="Raison de la suppression :" />

                <ComboBox fx:id="cmbReasons" prefHeight="40" promptText="Sélectionnez une raison" style="-fx-background-color: #1e2749; -fx-text-fill: white;" />

                <TextArea fx:id="txtCustomReason" prefHeight="100" promptText="Si 'Autre', veuillez préciser ici..." style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-control-inner-background: #1e2749;" wrapText="true" />

                <Label fx:id="lblCharCount" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="0/200" />
            </VBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button fx:id="btnCancel" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="Annuler" />
                <Button fx:id="btnConfirm" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="Confirmer la suppression" />
            </HBox>
        </VBox>
    </children>
</GridPane>