                                    </VBox>
                                </HBox>
                                <VBox spacing="3">
                                    <Label fx:id="lblDevisesActives" style="-fx-text-fill: #6366f1; -fx-font-size: 12; -fx-font-weight: 600;" text="EUR → EUR"/>
                                    <Label fx:id="lblTauxUpdate" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="En attente..."/>
                                </VBox>
