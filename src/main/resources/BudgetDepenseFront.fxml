                    <!-- Logo -->
                    <HBox alignment="CENTER" spacing="10">
                        <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                        <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate"/>
                        <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO"/>
                    </HBox>

                    <!-- Nav links (Updated) -->
                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:0 0 0 20;">
                        <HBox fx:id="btnDestinations" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                            <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="🌍"/>
                            <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Destinations"/>
                        </HBox>
                        <!-- Hébergement -->
                        <HBox fx:id="btnHebergement" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                            <Label style="-fx-font-size: 16;" text="🏨" />
                            <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergement" />
                        </HBox>

                        <!-- Catégories (replaces Itinéraires) -->
                        <HBox fx:id="btnCategories" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                            <Label style="-fx-font-size: 16;" text="📑" />
                            <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Catégories" />
                        </HBox>

                        <HBox fx:id="btnActivites" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                            <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="🏄"/>
                            <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités"/>
                        </HBox>

                        <HBox fx:id="btnVoyages" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                            <Label style="-fx-font-size: 16; -fx-text-fill: #475569;" text="✈️"/>
                            <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Voyages"/>
                        </HBox>

                        <HBox fx:id="btnBudgets" alignment="CENTER" spacing="8"
                              style="-fx-background-color: rgba(255,140,66,0.1); -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                            <Label style="-fx-font-size: 16; -fx-text-fill: #ff8c42;" text="💰"/>
                            <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14;" text="Budgets"/>
                        </HBox>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Assistant vocal -->
                    <HBox alignment="CENTER" spacing="12">
                        <Button fx:id="btnVoice" onAction="#handleToggleVoice"
                                style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 48; -fx-min-height: 48; -fx-font-size: 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,140,66,0.3), 10, 0, 2, 2); -fx-border-width: 0;"
                                text="🎙️">
                            <tooltip><Tooltip text="Cliquez pour parler — 'ajouter dépense', 'budget restant', 'exporter PDF'"/></tooltip>
                        </Button>
                        <VBox spacing="2">
                            <Label fx:id="lblVoiceStatus" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-weight: 500;" text="Assistant vocal"/>
                            <Label fx:id="lblVoiceText" style="-fx-text-fill: #0f172a; -fx-font-size: 12; -fx-font-style: italic;" maxWidth="200" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <!-- Bouton Alertes -->
                    <StackPane>
                        <Button onAction="#handleToggleAlertHistory"
                                style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444; -fx-background-radius: 12; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-border-width: 0;">
                            <graphic><HBox alignment="CENTER" spacing="6"><Label style="-fx-font-size: 16;" text="🔔"/><Label/></HBox></graphic>
                        </Button>
                        <Label fx:id="lblAlertBadge" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 2 6; -fx-min-width: 20; -fx-alignment: CENTER;" text="0" StackPane.alignment="TOP_RIGHT">
                            <StackPane.margin><Insets right="-5" top="-5"/></StackPane.margin>
                        </Label>
                    </StackPane>

                    <!-- Profil - Clickable -->
                    <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10"
                          style="-fx-background-color: #f1f5f9; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                        <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                        <VBox spacing="0">
                            <Label fx:id="lblUserName" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 13;" text="Yosr Boutaieb"/>
                            <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Administrateur"/>
                        </VBox>
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="▼"/>
                    </HBox>
                </HBox>

                <!-- Breadcrumb -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 8 32;">
                    <HBox fx:id="btnHome" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="🏠"/>
                    </HBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Accueil"/>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›"/>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Budgets"/>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›"/>
                    <Label fx:id="lblNomBudget" style="-fx-text-fill: #ff8c42; -fx-font-size: 12; -fx-font-weight: 600;" text="Gestion des budgets"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Panneau alertes (light) -->
                <HBox fx:id="alertHistoryPanel" alignment="CENTER_RIGHT" managed="false" style="-fx-background-color: transparent; -fx-padding: 5 32 0 0;" visible="false">
                    <VBox spacing="12" style="-fx-background-color: #ffffff; -fx-padding: 24; -fx-min-width: 380; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 5, 5); -fx-background-radius: 12; -fx-border-color: #ff8c42; -fx-border-width: 1;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-size: 22; -fx-text-fill: #ff8c42;" text="🔔"/>
                            <Label style="-fx-font-size: 18; -fx-font-weight: 700; -fx-text-fill: #0f172a;" text="Historique des alertes"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button onAction="#handleToggleAlertHistory" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-background-radius: 10; -fx-min-width: 34; -fx-min-height: 34; -fx-font-size: 14; -fx-cursor: hand; -fx-border-width: 0;" text="✕"/>
                        </HBox>
                        <Button onAction="#handleClearAlertHistory" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444; -fx-background-radius: 10; -fx-padding: 6 14; -fx-font-size: 12; -fx-cursor: hand; -fx-border-width: 0;" text="🗑 Vider l'historique"/>
                        <Separator/>
                        <VBox fx:id="alertHistoryList" spacing="10"/>
                    </VBox>
                </HBox>
            </VBox>
        </top>

        <!-- BOTTOM (light) -->
        <bottom>
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 10 28;">
                <Label style="-fx-text-fill: #10b981; -fx-font-size: 11; -fx-font-weight: 600;" text="● Connecté"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: —"/>
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="© 2026 TravelMate"/>
            </HBox>
        </bottom>

        <!-- CENTER -->
        <center>
            <ScrollPane fitToWidth="true"
                        style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
                <content>
                    <VBox maxWidth="1400" spacing="32">
                        <padding><Insets bottom="60" left="40" right="40" top="40"/></padding>

                        <!-- EN-TÊTE améliorée avec style carte (light) -->
                        <HBox alignment="CENTER_LEFT" spacing="24"
                              style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-border-color: #ff8c42; -fx-border-width: 0 0 0 4; -fx-border-radius: 20;">
                            <VBox fx:id="budgetIconContainer" alignment="CENTER"
                                  style="-fx-background-color: linear-gradient(to bottom right, #fff7ed, #ffedd5); -fx-background-radius: 20; -fx-min-width: 80; -fx-min-height: 80; -fx-effect: dropshadow(gaussian, rgba(255,140,66,0.2), 15, 0, 0, 3); -fx-border-color: rgba(255,140,66,0.3); -fx-border-width: 2; -fx-border-radius: 20;">
                                <Label fx:id="lblBudgetIcon" style="-fx-font-size: 40;" text="💰"/>
                            </VBox>

                            <VBox spacing="8" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <ComboBox fx:id="cmbVoyageSelector" promptText="Sélectionner un voyage"
                                              style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14; -fx-min-width: 280;"/>
                                    <Label fx:id="lblBudgetNom" style="-fx-font-weight: 700; -fx-font-size: 22; -fx-text-fill: #0f172a;" text="Sélectionnez un budget"/>
                                    <HBox fx:id="statusContainer" alignment="CENTER" spacing="6" style="-fx-background-color: #10b981; -fx-background-radius: 30; -fx-padding: 4 14;">
                                        <Label fx:id="lblBudgetStatut" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 12;" text="ACTIF"/>
                                    </HBox>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 14;">
                                        <Label style="-fx-font-size: 14; -fx-text-fill: #ff8c42;" text="📅"/>
                                        <Label fx:id="lblBudgetDates" style="-fx-text-fill: #0f172a; -fx-font-weight: 500; -fx-font-size: 12;" text="—"/>
                                    </HBox>
                                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 14;">
                                        <Label style="-fx-font-size: 14; -fx-text-fill: #ff8c42;" text="📍"/>
                                        <Label fx:id="lblBudgetDestination" style="-fx-text-fill: #0f172a; -fx-font-weight: 500; -fx-font-size: 12;" text="—"/>
                                    </HBox>
                                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 14;">
                                        <Label style="-fx-font-size: 14; -fx-text-fill: #ff8c42;" text="💱"/>
                                        <Label fx:id="lblBudgetDevise" style="-fx-text-fill: #0f172a; -fx-font-weight: 500; -fx-font-size: 12;" text="EUR"/>
                                    </HBox>
                                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 14;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 14; -fx-text-fill: #ff8c42;" text="📝"/>
                                        <Label fx:id="lblBudgetDescription" style="-fx-text-fill: #0f172a; -fx-font-weight: 400; -fx-font-size: 12;" text="—"/>
                                    </HBox>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 8 0 0 0;">
                                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #e0f2fe; -fx-background-radius: 20; -fx-padding: 6 14;">
                                        <Label style="-fx-font-size: 14; -fx-text-fill: #0284c7;" text="📈"/>
                                        <Label fx:id="lblInflationInfo" style="-fx-text-fill: #0f172a; -fx-font-weight: 500; -fx-font-size: 12;" wrapText="true"/>
                                    </HBox>
                                </HBox>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <!-- Boutons action budget + IA (modernisés) -->
                            <VBox spacing="8" alignment="CENTER_RIGHT">
                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <Button fx:id="btnModifierBudget" onAction="#handleModifierBudget"
                                            style="-fx-background-color: #ffb084; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 10 20; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,176,132,0.3), 8, 0, 2, 2); -fx-border-width: 0;">
                                        <graphic><HBox alignment="CENTER" spacing="8"><Label style="-fx-font-size: 14;" text="✏️"/><Label text="Modifier"/></HBox></graphic>
                                    </Button>
                                    <Button fx:id="btnSupprimerBudget" onAction="#handleSupprimerBudget"
                                            style="-fx-background-color: #ff6b4a; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 10 20; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,107,74,0.3), 8, 0, 2, 2); -fx-border-width: 0;">
                                        <graphic><HBox alignment="CENTER" spacing="8"><Label style="-fx-font-size: 14;" text="🗑️"/><Label text="Supprimer"/></HBox></graphic>
                                    </Button>
                                </HBox>
                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <Button onAction="#handleEcologicalAnalysis"
                                            style="-fx-background-color: #ffa726; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 10 20; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,167,38,0.3), 8, 0, 2, 2); -fx-border-width: 0;">
                                        <graphic><HBox alignment="CENTER" spacing="8"><Label style="-fx-font-size: 14;" text="🌿"/><Label text="Score Éco"/></HBox></graphic>
                                        <tooltip><Tooltip text="IA : Calculer l'empreinte carbone"/></tooltip>
                                    </Button>
                                    <Button onAction="#handleCrisisAnalysis"
                                            style="-fx-background-color: #f57c00; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 10 20; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(245,124,0,0.3), 8, 0, 2, 2); -fx-border-width: 0;">
                                        <graphic><HBox alignment="CENTER" spacing="8"><Label style="-fx-font-size: 14;" text="🚨"/><Label text="Plan B"/></HBox></graphic>
                                        <tooltip><Tooltip text="IA : Plan B financier"/></tooltip>
                                    </Button>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- KPI CARDS (light) -->
                        <HBox spacing="20">
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #ff8c42; -fx-border-width: 0 0 0 4; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 2, 2);">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                        <Label style="-fx-font-size: 24; -fx-text-fill: #ff8c42;" text="💰"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="BUDGET TOTAL"/>
                                        <Label fx:id="lblMontantTotal" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="0 €"/>
                                    </VBox>
                                </HBox>
                                <Label fx:id="lblInfoBudget" style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Budget non défini"/>
                            </VBox>
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #ef4444; -fx-border-width: 0 0 0 4; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 2, 2);">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #fef2f2; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                        <Label style="-fx-font-size: 24; -fx-text-fill: #ef4444;" text="💸"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="DÉPENSÉ"/>
                                        <Label fx:id="lblDepense" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0 €"/>
                                    </VBox>
                                </HBox>
                                <Label fx:id="lblPourcentageDepense" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-font-weight: 500;" text="↗ 0% du budget"/>
                            </VBox>
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #10b981; -fx-border-width: 0 0 0 4; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 2, 2);">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #e6f7e6; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                        <Label style="-fx-font-size: 24; -fx-text-fill: #10b981;" text="✨"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="RESTANT"/>
                                        <Label fx:id="lblRestant" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0 €"/>
                                    </VBox>
                                </HBox>
                                <Label fx:id="lblPourcentageRestant" style="-fx-text-fill: #10b981; -fx-font-size: 12; -fx-font-weight: 500;" text="✓ 0% disponible"/>
                            </VBox>
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #6366f1; -fx-border-width: 0 0 0 4; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 2, 2);">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #ede9fe; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
