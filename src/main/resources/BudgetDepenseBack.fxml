<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.BudgetBackController">

    <BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #f8fafc;">

        <!-- LEFT SIDEBAR -->
        <left>
            <VBox spacing="20" style="-fx-background-color: #0f172a; -fx-padding: 30 20; -fx-min-width: 260;" BorderPane.alignment="CENTER">

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="22" />
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="ADMIN" />
                </HBox>

                <Separator style="-fx-background-color: #334155;" />

                <!-- Profil admin -->
                <VBox spacing="12" alignment="CENTER">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="40" />
                    <VBox alignment="CENTER" spacing="4">
                        <Label style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 18;" text="Yosr Boutaieb" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-background-color: #1e293b; -fx-background-radius: 12; -fx-padding: 4 12;" text="Administrateur" />
                    </VBox>
                </VBox>

                <Separator style="-fx-background-color: #334155;" />

                <!-- Menu -->
                <VBox spacing="6">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 600; -fx-padding: 10 0 5 10;" text="NAVIGATION" />

                    <HBox spacing="15" style="-fx-background-color: #334155; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #ff8c42;" text="📊" />
                        <Label style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14;" text="Dashboard" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="3" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="🌍" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Destinations" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="🗺️" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Itinéraires" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="🏄" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="🏨" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergements" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: #ff8c42; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: white;" text="💰" />
                        <Label style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 14;" text="Budgets" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblMenuBudgetCount" style="-fx-text-fill: white; -fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 12; -fx-padding: 2 8; -fx-font-size: 11;" text="0" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="📈" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Rapports" />
                    </HBox>

                    <HBox spacing="15" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 12 15;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #94a3b8;" text="⚙️" />
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-weight: 500; -fx-font-size: 14;" text="Paramètres" />
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Pied de sidebar -->
                <VBox spacing="10">
                    <Separator style="-fx-background-color: #334155;" />
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="© 2026 TravelMate" />
                        <Circle fill="#ff8c42" radius="3" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="v3.0" />
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <!-- TOP BAR -->
        <top>
            <VBox>
                <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 15 30;">
                    <Label style="-fx-text-fill: #0f172a; -fx-font-size: 20; -fx-font-weight: 700;" text="Gestion des Budgets" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="20">
                        <HBox spacing="5">
                            <Label style="-fx-font-size: 18;" text="🔔" />
                            <Label style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 18; -fx-min-height: 18; -fx-font-size: 10; -fx-padding: 2;" text="3" />
                        </HBox>
                        <HBox spacing="10" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 5 15 5 5;">
                            <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="15" />
                            <Label style="-fx-text-fill: #0f172a; -fx-font-weight: 600;" text="Yosr B." />
                        </HBox>
                    </HBox>
                </HBox>

                <!-- Breadcrumb -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #ffffff; -fx-padding: 8 30;">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Accueil" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Backoffice" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                    <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 600;" text="Budgets" />
                </HBox>
            </VBox>
        </top>

        <!-- BOTTOM BAR -->
        <bottom>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 30;">
                <HBox alignment="CENTER" spacing="5">
                    <Circle fill="#10b981" radius="4" />
                    <Label style="-fx-text-fill: #10b981; -fx-font-size: 11;" text="Connecté" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: --" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="•" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Serveur: OK" />
            </HBox>
        </bottom>

        <!-- CENTER CONTENT -->
        <center>
            <ScrollPane fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent;">
                <content>
                    <VBox spacing="25">
                        <padding>
                            <Insets bottom="40" left="30" right="30" top="30" />
                        </padding>

                        <!-- KPI CARDS -->
                        <HBox spacing="20">
                            <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45;">
                                        <Label style="-fx-font-size: 22;" text="💰" />
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="TOTAL BUDGETS" />
                                        <Label fx:id="lblTotalBudgets" style="-fx-font-size: 28; -fx-font-weight: bold;" text="0" />
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #10b981; -fx-font-size: 11;" text="↑ 12% ce mois" />
                            </VBox>

                            <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #e6f7e6; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45;">
                                        <Label style="-fx-font-size: 22;" text="✓" />
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="BUDGETS ACTIFS" />
                                        <Label fx:id="lblBudgetsActifs" style="-fx-font-size: 28; -fx-font-weight: bold;" text="0" />
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Sur total budgets" />
                            </VBox>

                            <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox alignment="CENTER" style="-fx-background-color: #fff1e6; -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45;">
                                        <Label style="-fx-font-size: 22;" text="€" />
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="MONTANT GLOBAL" />
                                        <Label fx:id="lblMontantGlobal" style="-fx-font-size: 28; -fx-font-weight: bold;" text="0 €" />
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Tous budgets confondus" />
                            </VBox>
                        </HBox>

                        <!-- SECTION STATISTIQUES PAR CATÉGORIE -->
                        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;">
                            <Label style="-fx-font-size: 18; -fx-font-weight: 700;" text="📊 Statistiques par catégorie" />

                            <HBox spacing="20">
                                <!-- Graphique circulaire -->
                                <VBox spacing="15" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: 600;" text="Répartition des dépenses" />
                                    <PieChart fx:id="pieChartRepartition" prefHeight="280" />
                                </VBox>

                                <!-- Top 5 catégories -->
                                <VBox spacing="15" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-weight: 600;" text="Top 5 catégories les plus dépensées" />
                                    <TableView fx:id="tableTopCategories" prefHeight="280">
                                        <columns>
                                            <TableColumn fx:id="colCategorieNom" prefWidth="150" text="Catégorie" />
                                            <TableColumn fx:id="colCategorieMontant" prefWidth="120" text="Montant (€)" />
                                            <TableColumn fx:id="colCategoriePourcentage" prefWidth="100" text="Pourcentage" />
                                        </columns>
                                    </TableView>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- SECTION BUDGETS -->
                        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;">
                            <Label style="-fx-font-size: 18; -fx-font-weight: 700;" text="📋 Liste des budgets" />

                            <TableView fx:id="tableBudgets" prefHeight="200">
                                <columns>
                                    <TableColumn fx:id="colIdBudget" prefWidth="50" text="ID" />
                                    <TableColumn fx:id="colLibelleBudget" prefWidth="180" text="Libellé" />
                                    <TableColumn fx:id="colMontantTotal" prefWidth="130" text="Montant" />
                                    <TableColumn fx:id="colDeviseBudget" prefWidth="70" text="Devise" />
                                    <TableColumn fx:id="colStatutBudget" prefWidth="100" text="Statut" />
                                    <TableColumn fx:id="colVoyageAssocie" prefWidth="160" text="Voyage" />
                                    <TableColumn fx:id="colDestination" prefWidth="130" text="Destination" />
                                    <TableColumn fx:id="colActions" prefWidth="100" text="Actions" />
                                </columns>
                            </TableView>
                        </VBox>

                        <!-- SECTION DÉPENSES -->
                        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Label style="-fx-font-size: 18; -fx-font-weight: 700;" text="💸 Dépenses du budget sélectionné" />
                                <Label fx:id="lblBudgetNom" style="-fx-text-fill: #ff8c42; -fx-font-weight: 600;" text="Aucun budget sélectionné" />
                            </HBox>

                            <HBox spacing="15">
                                <VBox>
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="TOTAL" />
                                    <Label fx:id="lblMontantTotal" style="-fx-font-weight: bold; -fx-font-size: 16;" text="0 €" />
                                </VBox>
                                <VBox>
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="DÉPENSÉ" />
                                    <Label fx:id="lblDepense" style="-fx-font-weight: bold; -fx-font-size: 16;" text="0 €" />
                                </VBox>
                                <VBox>
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="RESTANT" />
                                    <Label fx:id="lblRestant" style="-fx-font-weight: bold; -fx-font-size: 16;" text="0 €" />
                                </VBox>
                            </HBox>

                            <TableView fx:id="tableDepenses" prefHeight="200">
                                <columns>
                                    <TableColumn fx:id="colLibelle" prefWidth="180" text="Libellé" />
                                    <TableColumn fx:id="colCategorie" prefWidth="130" text="Catégorie" />
                                    <TableColumn fx:id="colMontant" prefWidth="120" text="Montant" />
                                    <TableColumn fx:id="colDevise" prefWidth="70" text="Devise" />
                                    <TableColumn fx:id="colDate" prefWidth="100" text="Date" />
                                    <TableColumn fx:id="colPaiement" prefWidth="130" text="Paiement" />
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>