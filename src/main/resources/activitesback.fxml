<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controlles.ACTback"
            stylesheets="@activitesback.css"
            prefHeight="900" prefWidth="1400" style="-fx-background-color: #0a0e27;">

    <!-- TOP NAVIGATION BAR -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="20" right="32" bottom="20" left="32"/>
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                    <Label text="TravelMate" style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                    <Label text="PRO" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Navigation Menu -->
                <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 20;">
                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="🌍" style="-fx-font-size: 16;"/>
                        <Label text="Destinations" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="🗺️" style="-fx-font-size: 16;"/>
                        <Label text="Itinéraires" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <!-- Activités - Active -->
                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="🎯" style="-fx-font-size: 16;"/>
                        <Label text="Activités" style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="📑" style="-fx-font-size: 16;"/>
                        <Label text="Catégories" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="✈️" style="-fx-font-size: 16;"/>
                        <Label text="Voyages" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="💰" style="-fx-font-size: 16;"/>
                        <Label text="Budgets" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search Bar -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-padding: 8 20;">
                    <Label text="🔍" style="-fx-font-size: 14;"/>
                    <TextField fx:id="searchField" promptText="Rechercher une activité..." style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #64748b; -fx-border-color: transparent; -fx-font-size: 13;" prefWidth="150"/>
                </HBox>

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                    <VBox spacing="0">
                        <Label text="Yosr Boutaieb" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 13;"/>
                        <Label text="Administrateur" style="-fx-text-fill: #64748b; -fx-font-size: 10;"/>
                    </VBox>
                    <Label text="▼" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
                </HBox>
            </HBox>

            <!-- Secondary Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 8 32;">
                <HBox spacing="8" alignment="CENTER">
                    <Label text="FILTRES RAPIDES :" style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;"/>
                    <Label text="Toutes les activités" style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;"/>
                    <Label text="Actives" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;"/>
                    <Label text="Récentes" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="📅 Février 2026" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;"/>

                <!-- Bouton Front Office (vert) -->
                <Button fx:id="btnFrontOffice" text="👤 Front Office" onAction="#handleFrontOffice"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 600;
                               -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 12;
                               -fx-border-color: #34d399; -fx-border-width: 1; -fx-border-radius: 20;"/>

                <!-- Bouton vers catégories (violet) -->
                <Button fx:id="btnVersCategories" text="📑 Gérer les Catégories" onAction="#handleVersCategories"
                        style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: 600;
                               -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 12;
                               -fx-border-color: #818cf8; -fx-border-width: 1; -fx-border-radius: 20;"/>

                <!-- Bouton nouvelle activité (orange) -->
                <Button text="+ Nouvelle Activité" onAction="#handleAjouter"
                        style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-font-weight: 600;
                               -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #0a0e27; -fx-padding: 32;">

            <!-- Page Header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="🎯" style="-fx-font-size: 28;"/>
                <Label text="Gestion des Activités" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="BACK OFFICE" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 6 14; -fx-font-size: 11; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Statistics -->
                <HBox spacing="20">
                    <VBox spacing="4" alignment="CENTER">
                        <Label fx:id="lblTotalActivites" text="0" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ff8c42;"/>
                        <Label text="Activités" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Action Buttons Bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="✏️ Modifier" fx:id="btnModifier" onAction="#handleModifier" disable="true"
                        style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42;
                               -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 10 20;
                               -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1;
                               -fx-border-radius: 10; -fx-font-size: 13;"/>
                <Button text="🗑️ Supprimer" fx:id="btnSupprimer" onAction="#handleSupprimer" disable="true"
                        style="-fx-background-color: rgba(239,68,68,0.15); -fx-text-fill: #ef4444;
                               -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 10 20;
                               -fx-cursor: hand; -fx-border-color: #ef4444; -fx-border-width: 1;
                               -fx-border-radius: 10; -fx-font-size: 13;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Actualiser" onAction="#handleActualiser"
                        style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8;
                               -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;
                               -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 10;
                               -fx-font-weight: 500; -fx-font-size: 13;"/>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="tableActivites" VBox.vgrow="ALWAYS" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-border-color: #ff8c42; -fx-border-width: 2; -fx-border-radius: 20;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                    <TableColumn fx:id="colBudget" text="Budget (€)" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNiveauDifficulte" text="Difficulté" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colLieu" text="Lieu" prefWidth="120"/>
                    <TableColumn fx:id="colAgeMin" text="Âge Min" prefWidth="80" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDuree" text="Durée (h)" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <!-- NOUVELLE COLONNE IMAGE -->
                    <TableColumn fx:id="colImage" text="Image" prefWidth="80" style="-fx-alignment: CENTER;"/>
                </columns>

                <placeholder>
                    <VBox alignment="CENTER" spacing="12">
                        <Label text="📊" style="-fx-font-size: 48;"/>
                        <Label text="Aucune activité à afficher" style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
                        <Button text="+ Ajouter une activité" onAction="#handleAjouter" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    </VBox>
                </placeholder>
            </TableView>

            <!-- Bottom Gradient -->
            <Rectangle fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" arcHeight="8" arcWidth="8">
                <VBox.margin>
                    <Insets top="20"/>
                </VBox.margin>
            </Rectangle>

        </VBox>
    </center>

</BorderPane>