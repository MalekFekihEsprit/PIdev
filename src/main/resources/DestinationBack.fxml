<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.DestinationBackController">

    <!-- TOP NAV - DARK MODE WITH ORANGE ACCENT -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding><Insets bottom="20" left="32" right="32" top="20" /></padding>

                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications with badge -->
                <HBox alignment="CENTER" style="-fx-background-color: #1e2749; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🔔" />
                    <Circle fill="#ff8c42" radius="6" translateX="10" translateY="-10" />
                </HBox>

                <!-- User Profile - CLICKABLE with dynamic labels -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 13;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="..." />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="▼" />
                </HBox>
            </HBox>

            <!-- Secondary Navigation - Quick Filters -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 8 32;">
                <HBox alignment="CENTER" spacing="8">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="FILTRES RAPIDES :" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Toutes" />
                    <Label style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Méditerranéen" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Tropical" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Montagnard" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <!-- SIDEBAR DASHBOARD - DARK MODE WITH ORANGE -->
    <left>
        <VBox prefWidth="280" spacing="8" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>

            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #64748b; -fx-letter-spacing: 1.5;" text="DASHBOARD" />

            <VBox spacing="4">
                <padding><Insets top="12" /></padding>

                <!-- Destinations - Active -->
                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🌍" />
                    <Label style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14;" text="Destinations" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblSidebarDestinationCount" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10; -fx-padding: 2 8; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="0" />
                </HBox>

                <!-- Hébergement -->
                <HBox fx:id="btnHebergement" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🏨" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergement" />
                </HBox>

                <!-- Utilisateurs -->
                <HBox fx:id="btnUsers" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="👥" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Utilisateurs" />
                </HBox>

                <!-- Statistiques -->
                <HBox fx:id="btnStats" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="📊" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Statistiques" />
                </HBox>

                <!-- Itinéraires -->
                <HBox fx:id="btnItineraires" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🗺️" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Itinéraires" />
                </HBox>

                <!-- Activités -->
                <HBox fx:id="btnActivites" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🏄" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités" />
                </HBox>

                <!-- Voyages -->
                <HBox fx:id="btnVoyages" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="✈️" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Voyages" />
                </HBox>

                <!-- Budgets -->
                <HBox fx:id="btnBudgets" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="💰" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Budgets" />
                </HBox>
            </VBox>

            <!-- DIVIDER -->
            <Rectangle fill="#1e2749" height="1" width="240"><VBox.margin><Insets bottom="12" top="12" /></VBox.margin></Rectangle>

            <!-- STATS RAPIDES -->
            <VBox spacing="12" style="-fx-background-color: #0a0e27; -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 16;">
                <Label style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 11; -fx-letter-spacing: 1;" text="STATISTIQUES GLOBALES" />
                <GridPane hgap="10" vgap="10">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Total destinations:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="lblTotalDestinations" style="-fx-font-weight: bold; -fx-text-fill: #ff8c42; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Climats:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="lblClimatsCount" style="-fx-font-weight: bold; -fx-text-fill: #f87171; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Saisons:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="lblSaisonsCount" style="-fx-font-weight: bold; -fx-text-fill: #34d399; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Pays:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label fx:id="lblPaysCount" style="-fx-font-weight: bold; -fx-text-fill: #60a5fa; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <columnConstraints><ColumnConstraints /><ColumnConstraints halignment="RIGHT" /></columnConstraints>
                    <rowConstraints><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /></rowConstraints>
                </GridPane>
            </VBox>
        </VBox>
    </left>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 1 0 0 0; -fx-padding: 10 28;">
            <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 500;" text="● Connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: 12 Fév 2026, 15:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="28"><padding><Insets bottom="60" left="36" right="36" top="36" /></padding>

                    <VBox spacing="8">
                        <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Gestion des Destinations" />
                        <HBox spacing="8">
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 14;" text="Administration et configuration des destinations de voyage" />
                            <Label style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 16; -fx-padding: 2 12; -fx-font-size: 12; -fx-font-weight: 600;" text="● Mode administration" />
                        </HBox>
                    </VBox>

                    <!-- KPI CARDS - 4 CARDS NOW (REMOVED REGIONS CARD) -->
                    <HBox spacing="16">
                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #ff8c42; -fx-border-width: 2; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🌍" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="TOTAL DESTINATIONS" />
                                    <Label fx:id="lblDestinationsTotal" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #f87171; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(248,113,113,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🌡️" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="CLIMATS" />
                                    <Label fx:id="lblClimatsTotal" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #f87171;" text="0" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-background-color: rgba(248,113,113,0.15); -fx-text-fill: #f87171; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: 600; -fx-font-size: 11;" text="🌍 Types de climats" />
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #34d399; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(52,211,153,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🗓️" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="SAISONS" />
                                    <Label fx:id="lblSaisonsTotal" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #34d399;" text="0" />
                                </VBox>
                            </HBox>
                            <Label style="-fx-background-color: rgba(52,211,153,0.15); -fx-text-fill: #34d399; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: 600; -fx-font-size: 11;" text="✓ Couverture saisonnière" />
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #60a5fa; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(96,165,250,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="📍" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="PAYS" />
                                    <Label fx:id="lblPaysTotal" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #60a5fa;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- REGION STATISTICS SECTION - WITH PIE CHART -->
                    <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 24; -fx-padding: 24; -fx-border-color: #f59e0b; -fx-border-width: 1; -fx-border-radius: 24;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox alignment="CENTER" style="-fx-background-color: rgba(245,158,11,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                <Label style="-fx-font-size: 24;" text="📍" />
                            </VBox>
                            <VBox spacing="2">
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="Statistiques des Régions" />
                                <HBox spacing="16">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Total régions:" />
                                    <Label fx:id="lblTotalRegions" style="-fx-text-fill: #f59e0b; -fx-font-weight: 600; -fx-font-size: 14;" text="0" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="•" />
                                    <Label fx:id="lblRegionCoverage" style="-fx-text-fill: #10b981; -fx-font-size: 12;" text="0% des destinations ont une région" />
                                </HBox>
                            </VBox>
                        </HBox>

                        <HBox spacing="20" alignment="CENTER">
                            <!-- Pie Chart -->
                            <PieChart fx:id="regionPieChart" prefHeight="300" prefWidth="400"
                                      style="-fx-text-fill: white; -fx-font-size: 11;" />

                            <!-- Region Details -->
                            <VBox fx:id="regionStatsContainer" spacing="8"
                                  style="-fx-background-color: #0a0e27; -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 16;"
                                  prefWidth="300" prefHeight="250">
                                <!-- Will be populated dynamically -->
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="16">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 24; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="Liste des Destinations" />
                            <Label fx:id="lblDestinationCount" style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: 600; -fx-font-size: 11;" text="0 destinations" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="8">
                                <Button fx:id="btnShowMap" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="🗺️ Carte" />
                                <Button fx:id="btnSuggestHotels" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="🏨 Suggérer Hôtels" />
                                <Button fx:id="btnAjouter" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ Ajouter" />
                                <Button fx:id="btnSupprimer" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="🗑️ Supprimer" />
                                <HBox fx:id="btnSearch" alignment="CENTER" style="-fx-background-color: #1e2749; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                                    <Label style="-fx-font-size: 16; -fx-text-fill: #94a3b8;" text="🔍" />
                                </HBox>
                                <HBox fx:id="btnFilter" alignment="CENTER" style="-fx-background-color: #1e2749; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                                    <Label style="-fx-font-size: 16; -fx-text-fill: #94a3b8;" text="📊" />
                                </HBox>
                            </HBox>
                        </HBox>

                        <TableView fx:id="tableDestinations" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 20;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                <TableColumn fx:id="colNom" prefWidth="150" text="Nom" />
                                <TableColumn fx:id="colPays" prefWidth="120" text="Pays" />
                                <TableColumn fx:id="colRegion" prefWidth="120" text="Région" />
                                <TableColumn fx:id="colDescription" prefWidth="250" text="Description" />
                                <TableColumn fx:id="colClimat" prefWidth="120" text="Climat" />
                                <TableColumn fx:id="colSaison" prefWidth="120" text="Saison idéale" />
                                <TableColumn fx:id="colAddedBy" prefWidth="150" text="Ajouté par" />
                                <TableColumn fx:id="colActions" prefWidth="150" text="Actions" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="12">
                                    <Label style="-fx-font-size: 32;" text="🗺️" />
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 14;" text="Aucune destination à afficher" />
                                </VBox>
                            </placeholder>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="8">
                            <Label fx:id="lblPaginationInfo" style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="0-0 sur 0 destinations" />
                            <HBox fx:id="paginationContainer" spacing="4" />
                        </HBox>
                    </VBox>

                    <Rectangle arcHeight="8" arcWidth="8" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" width="1200"><VBox.margin><Insets top="20" /></VBox.margin></Rectangle>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>