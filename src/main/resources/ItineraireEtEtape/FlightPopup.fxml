<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ItineraireEtEtape.FlightPopupController"
            prefWidth="500"
            style="-fx-background-color: white; -fx-background-radius: 10;">

    <content>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8fafc;">
            <content>
                <VBox spacing="15" style="-fx-background-color: #f8fafc; -fx-padding: 20;">

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size: 28;" text="✈️" />
                        <Label fx:id="titleLabel" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Vols disponibles" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleRefresh" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-cursor: hand;" text="🔄 Actualiser" />
                    </HBox>

                    <!-- Info destination -->
                    <VBox spacing="5" style="-fx-background-color: #fff7ed; -fx-background-radius: 10; -fx-padding: 15;">
                        <Label fx:id="destinationLabel" style="-fx-font-weight: 600; -fx-text-fill: #ff8c42; -fx-font-size: 16;" text="Destination: Zaghouan" />
                        <Label fx:id="dateLabel" style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Date: 27/02/2026" />
                    </VBox>

                    <!-- Loading indicator -->
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefWidth="50" prefHeight="50" style="-fx-padding: 20;" />

                    <!-- Error message -->
                    <Label fx:id="errorLabel" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-padding: 12; -fx-background-radius: 8;" wrapText="true" visible="false" managed="false" />

                    <!-- No flights message -->
                    <Label fx:id="noFlightsLabel" style="-fx-text-fill: #64748b; -fx-font-size: 15; -fx-padding: 30;" text="Aucun vol trouvé pour cette destination" visible="false" managed="false" />

                    <!-- Flights container -->
                    <VBox fx:id="flightsContainer" spacing="12" />

                    <!-- Close button -->
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Button onAction="#handleClose" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 24; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand;" text="Fermer" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </content>

    <ButtonType fx:constant="CANCEL" />

</DialogPane>