<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ItineraireEtEtape.GestionItinerairesController">

    <!-- TOP NAV - DARK MODE WITH ORANGE ACCENT (identique à DestinationBack) -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding><Insets bottom="20" left="32" right="32" top="20" /></padding>

                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications with badge -->
                <HBox alignment="CENTER" style="-fx-background-color: #1e2749; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🔔" />
                    <Circle fill="#ff8c42" radius="6" translateX="10" translateY="-10" />
                </HBox>

                <!-- User Profile - CLICKABLE -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 13;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="..." />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="▼" />
                </HBox>
            </HBox>

            <!-- Secondary Navigation - Quick Filters -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 8 32;">
                <HBox alignment="CENTER" spacing="8">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="FILTRES RAPIDES :" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Tous" />
                    <Label style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Récents" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Populaires" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <!-- SIDEBAR - MENU ADMINISTRATION (identique à DestinationBack) -->
    <left>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #111633; -fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 1 0 0;">
            <VBox prefWidth="280" spacing="8" style="-fx-background-color: #111633;">
                <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>

                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #64748b; -fx-letter-spacing: 1.5;" text="DASHBOARD" />

                <VBox spacing="4">
                    <padding><Insets top="12" /></padding>

                    <!-- Destinations -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleDestinationsClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🌍" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Destinations" />
                    </HBox>

                    <!-- Hébergement -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleHebergementClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🏨" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergement" />
                    </HBox>

                    <!-- Itinéraires - ACTIF -->
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="🗺️" />
                        <Label style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14;" text="Itinéraires" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblSidebarItinerairesCount" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10; -fx-padding: 2 8; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="0" />
                    </HBox>

                    <!-- Activités -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleActivitesClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🏄" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités" />
                    </HBox>

                    <!-- Catégories -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleCategoriesClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="📑" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Catégories" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleVoyagesClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="✈️" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleBudgetsClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="💰" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Budgets" />
                    </HBox>

                    <!-- Utilisateurs -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleUsersClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="👥" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Utilisateurs" />
                    </HBox>

                    <!-- Statistiques -->
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleStatsClick" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="📊" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Statistiques" />
                    </HBox>
                </VBox>

                <!-- DIVIDER -->
                <Rectangle fill="#1e2749" height="1" width="240"><VBox.margin><Insets bottom="12" top="12" /></VBox.margin></Rectangle>

                <!-- STATS RAPIDES -->
                <VBox spacing="12" style="-fx-background-color: #0a0e27; -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 16;">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 11; -fx-letter-spacing: 1;" text="STATISTIQUES GLOBALES" />
                    <GridPane hgap="10" vgap="10">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Itinéraires:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="statsTotalItineraires" style="-fx-font-weight: bold; -fx-text-fill: #ff8c42; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Étapes:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="statsTotalEtapes" style="-fx-font-weight: bold; -fx-text-fill: #34d399; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Destinations:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="statsTotalDestinations" style="-fx-font-weight: bold; -fx-text-fill: #f87171; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <columnConstraints><ColumnConstraints /><ColumnConstraints halignment="RIGHT" /></columnConstraints>
                        <rowConstraints><RowConstraints /><RowConstraints /><RowConstraints /></rowConstraints>
                    </GridPane>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- BOUTON RETOUR -->
                <Button onAction="#handleRetourVersItineraire" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 10; -fx-padding: 8 12; -fx-font-weight: 600; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 10; -fx-font-size: 12;" text="← Retour" />
            </VBox>
        </ScrollPane>
    </left>

    <!-- BOTTOM STATUS (identique à DestinationBack) -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 1 0 0 0; -fx-padding: 10 28;">
            <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 500;" text="● Connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: 12 Fév 2026, 15:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT (contenu original conservé mais stylisé) -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20">
                    <padding>
                        <Insets bottom="40" left="30" right="30" top="30" />
                    </padding>

                    <!-- HEADER -->
                    <VBox spacing="4">
                        <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Gestion des Itinéraires" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 14;" text="Administration complète des itinéraires et étapes" />
                    </VBox>

                    <!-- KPI CARDS (stylisés) -->
                    <HBox spacing="16">
                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🗺" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="ITINÉRAIRES" />
                                    <Label fx:id="kpiItineraires" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #34d399; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(52,211,153,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="📅" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="ÉTAPES" />
                                    <Label fx:id="kpiEtapes" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #34d399;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #f87171; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(248,113,113,0.15); -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🌍" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="DESTINATIONS" />
                                    <Label fx:id="kpiDestinations" style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #f87171;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- BARRE D'ACTIONS -->
                    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #111633; -fx-background-radius: 16; -fx-padding: 15 20;">
                        <Button fx:id="btnNouvelItineraire" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 12;" text="➕ Nouvel Itinéraire">
                            <tooltip><Tooltip text="Créer un nouvel itinéraire" /></tooltip>
                        </Button>
                        <Button fx:id="btnNouvelleEtape" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 12;" text="➕ Nouvelle Étape">
                            <tooltip><Tooltip text="Ajouter une nouvelle étape" /></tooltip>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-padding: 5 15;">
                            <Label style="-fx-font-size: 14;" text="🔍" />
                            <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-pref-width: 200; -fx-font-size: 12;" />
                        </HBox>
                    </HBox>

                    <!-- FILTRES -->
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #111633; -fx-background-radius: 16; -fx-padding: 15 20;">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 600;" text="Filtres :" />
                        <ComboBox fx:id="comboDestination" prefWidth="180" promptText="Destination" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 12;" />
                        <DatePicker fx:id="dateDebut" promptText="Date début" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 8; -fx-font-size: 12;" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="→" />
                        <DatePicker fx:id="dateFin" promptText="Date fin" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-border-color: #ff8c42; -fx-border-radius: 8; -fx-font-size: 12;" />
                        <Button fx:id="btnFiltrer" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 16; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 12;" text="Appliquer" />
                        <Button fx:id="btnReinitialiser" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 8; -fx-padding: 6 16; -fx-font-weight: 600; -fx-cursor: hand; -fx-font-size: 12;" text="Réinitialiser" />
                    </HBox>

                    <!-- TAB PANE avec tables -->
                    <TabPane style="-fx-background-color: #111633; -fx-background-radius: 16; -fx-tab-min-height: 40;" VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab closable="false" text="Itinéraires">
                                <content>
                                    <VBox spacing="15" style="-fx-padding: 20;">
                                        <TableView fx:id="tableItineraires" prefHeight="350" style="-fx-background-color: #1e2749; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                                <TableColumn fx:id="colNom" prefWidth="150" text="Nom" />
                                                <TableColumn fx:id="colDescription" prefWidth="250" text="Description" />
                                                <TableColumn fx:id="colVoyage" prefWidth="150" text="Voyage" />
                                                <TableColumn fx:id="colDestination" prefWidth="150" text="Destination" />
                                                <TableColumn fx:id="colNbEtapes" prefWidth="80" text="Étapes" />
                                                <TableColumn fx:id="colActions" prefWidth="120" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </content>
                            </Tab>
                            <Tab closable="false" text="Étapes">
                                <content>
                                    <VBox spacing="15" style="-fx-padding: 20;">
                                        <TableView fx:id="tableEtapes" prefHeight="350" style="-fx-background-color: #1e2749; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colEtapeId" prefWidth="60" text="ID" />
                                                <TableColumn fx:id="colEtapeHeure" prefWidth="80" text="Heure" />
                                                <TableColumn fx:id="colEtapeDescription" prefWidth="200" text="Description" />
                                                <TableColumn fx:id="colEtapeActivite" prefWidth="150" text="Activité" />
                                                <TableColumn fx:id="colEtapeItineraire" prefWidth="150" text="Itinéraire" />
                                                <TableColumn fx:id="colEtapeLieu" prefWidth="150" text="Lieu" />
                                                <TableColumn fx:id="colEtapeDuree" prefWidth="80" text="Durée" />
                                                <TableColumn fx:id="colEtapeActions" prefWidth="120" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </content>
                            </Tab>
                        </tabs>
                    </TabPane>

                    <!-- FOOTER DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
