<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="720" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ItineraireEtEtape.PageModifierItineraire">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TOP NAVIGATION BAR (copiée de PageItineraire.fxml)       -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                <padding>
                    <Insets bottom="12" left="24" right="24" top="12" />
                </padding>

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 10; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- Navigation Menu - TOUS LES BOUTONS -->
                <HBox alignment="CENTER_LEFT" spacing="4" style="-fx-padding: 0 0 0 20;">

                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Hébergements -->
                    <HBox fx:id="btnHebergement" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏨" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Hébergements" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Catégories -->
                    <HBox fx:id="btnCategories" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="📑" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Catégories" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="6" style="-fx-background-color: rgba(255,140,66,0.08); -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand; -fx-border-color: rgba(255,140,66,0.5); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14;" text="✈" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 700; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 38; -fx-min-height: 38; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 50;">
                    <Label style="-fx-font-size: 15;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #f8fafc; -fx-background-radius: 25; -fx-padding: 5 14 5 5; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 25;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="15" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #94a3b8; -fx-font-size: 9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 8;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb avec flèche de retour -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0; -fx-padding: 8 24;">
                <!-- Flèche de retour -->
                <Button onAction="#handleRetour"
                        style="-fx-background-color: transparent; -fx-text-fill: #ff8c42; -fx-font-size: 18; -fx-cursor: hand; -fx-padding: 0 5 0 0;"
                        text="←">
                    <tooltip>
                        <Tooltip text="Retour à la liste des itinéraires" />
                    </tooltip>
                </Button>

                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="✈️ Voyages" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="🗺️ Itinéraires" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="Modifier itinéraire" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblVoyageContext" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 10; -fx-font-weight: 600;" text="Modification" />
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT                                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets bottom="30" left="24" right="24" top="24" />
            </padding>

            <!-- HEADER SECTION -->
            <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 18; -fx-min-width: 60; -fx-min-height: 60;">
                    <Label style="-fx-font-size: 36;" text="✏️" />
                </VBox>

                <VBox spacing="6">
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Modifier itinéraire" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Modifiez les informations de l'itinéraire" />
                </VBox>
            </HBox>

            <!-- FORM CARD -->
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

                <!-- Nom de l'itinéraire -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Nom de l'itinéraire *" />
                    <Label style="-fx-text-fill: #ef4444; -fx-font-size: 10;" text="(maximum 10 caractères)" />
                    <TextField fx:id="nomField" promptText="Ex: Paris 2024" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />
                </VBox>

                <!-- Description -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Description" />
                    <TextArea fx:id="descriptionField" prefRowCount="4" promptText="Décrivez votre itinéraire..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8;" wrapText="true" />
                </VBox>

                <!-- Voyage associé -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Voyage associé *" />
                    <ComboBox fx:id="voyageCombo" promptText="Sélectionner un voyage" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4;" HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Choisissez le voyage auquel cet itinéraire appartient" />
                </VBox>

                <!-- Message d'erreur -->
                <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #ef4444; -fx-font-size: 11;" visible="false" wrapText="true" />

                <!-- Boutons d'action -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#handleAnnuler" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Annuler" />
                    <Button onAction="#handleModifier" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Modifier l'itinéraire" />
                </HBox>
            </VBox>

            <!-- BOTTOM DECORATION -->
            <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" />
        </VBox>
    </center>
</BorderPane>