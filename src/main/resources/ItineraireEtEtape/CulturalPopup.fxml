<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ItineraireEtEtape.CulturalPopupController"
            prefWidth="550"
            style="-fx-background-color: white; -fx-background-radius: 10;">

    <content>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="15" style="-fx-padding: 20;">

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size: 28;" text="🌍" />
                        <Label fx:id="titleLabel" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Conseils culturels" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleOpenWikivoyage"
                                style="-fx-background-color: #f1f5f9; -fx-text-fill: #3b82f6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-cursor: hand;"
                                text="📖 Voir sur Wikivoyage" />
                    </HBox>

                    <!-- Destination -->
                    <Label fx:id="destinationLabel" style="-fx-font-size: 14; -fx-text-fill: #ff8c42; -fx-font-weight: 600;" text="Destination: " />

                    <!-- Source -->
                    <Label fx:id="sourceLabel" style="-fx-font-size: 11; -fx-text-fill: #64748b; -fx-font-style: italic;" text="Source: Wikivoyage" />

                    <Separator style="-fx-background-color: #e2e8f0;" />

                    <!-- Message si pas d'info -->
                    <Label fx:id="noInfoLabel" style="-fx-text-fill: #64748b; -fx-font-size: 14; -fx-padding: 20;"
                           text="Aucune information culturelle spécifique trouvée pour cette destination."
                           visible="false" managed="false" />

                    <!-- Section Respect -->
                    <VBox fx:id="respectContainer" spacing="8" visible="true" managed="true">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size: 16;" text="🎌" />
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 14;" text="Respect culturel" />
                        </HBox>
                        <VBox fx:id="respectContent" spacing="4" style="-fx-padding: 0 0 0 20;">
                            <!-- Les points seront ajoutés dynamiquement -->
                        </VBox>
                    </VBox>

                    <!-- Section Sécurité -->
                    <VBox fx:id="safetyContainer" spacing="8" visible="true" managed="true">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size: 16;" text="🛡️" />
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 14;" text="Sécurité" />
                        </HBox>
                        <VBox fx:id="safetyContent" spacing="4" style="-fx-padding: 0 0 0 20;">
                            <!-- Les points seront ajoutés dynamiquement -->
                        </VBox>
                    </VBox>

                    <!-- Section Compréhension -->
                    <VBox fx:id="understandContainer" spacing="8" visible="true" managed="true">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size: 16;" text="📚" />
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 14;" text="À savoir" />
                        </HBox>
                        <VBox fx:id="understandContent" spacing="4" style="-fx-padding: 0 0 0 20;">
                            <!-- Les points seront ajoutés dynamiquement -->
                        </VBox>
                    </VBox>

                    <!-- Bouton fermer -->
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Button onAction="#handleClose"
                                style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 24; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand;"
                                text="Fermer" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </content>

    <ButtonType fx:constant="CANCEL" />

</DialogPane>