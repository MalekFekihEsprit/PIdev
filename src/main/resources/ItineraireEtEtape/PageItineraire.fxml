<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane fx:id="mainBorderPane" prefHeight="720" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ItineraireEtEtape.PageItineraire">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TOP NAVIGATION BAR                                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                <padding>
                    <Insets bottom="12" left="24" right="24" top="12" />
                </padding>

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 10; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- Navigation Menu -->
                <HBox alignment="CENTER_LEFT" spacing="4" style="-fx-padding: 0 0 0 20;">
                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Hébergements -->
                    <HBox fx:id="btnHebergement" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏨" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Hébergements" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Catégories -->
                    <HBox fx:id="btnCategories" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="📑" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Catégories" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="6" style="-fx-background-color: rgba(255,140,66,0.08); -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand; -fx-border-color: rgba(255,140,66,0.5); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14;" text="✈" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 700; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 38; -fx-min-height: 38; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 50;">
                    <Label style="-fx-font-size: 15;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #f8fafc; -fx-background-radius: 25; -fx-padding: 5 14 5 5; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 25;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="15" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #94a3b8; -fx-font-size: 9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 8;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb avec flèche de retour -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0; -fx-padding: 8 24;">
                <!-- Flèche de retour -->
                <Button onAction="#handleRetour" style="-fx-background-color: transparent; -fx-text-fill: #ff8c42; -fx-font-size: 18; -fx-cursor: hand; -fx-padding: 0 5 0 0;" text="←">
                    <tooltip>
                        <Tooltip text="Retour à la page précédente" />
                    </tooltip>
                </Button>

                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="✈ Voyages" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="🗺 Itinéraires" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblVoyageContext" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 10; -fx-font-weight: 600;" text="Voyage: Tous" />
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- BOTTOM STATUS BAR                                         -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 24;">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Circle fill="#10b981" radius="3.5" />
                <Label style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 600;" text="Connecté" />
            </HBox>
            <Rectangle fill="#e2e8f0" height="12" width="1" />
            <Label fx:id="lblItinerairesActifsFooter" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="0 itinéraires actifs" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="© 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT - PAGE ITINÉRAIRES                           -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30" left="24" right="24" top="24" />
                    </padding>

                    <!-- HEADER SECTION AVEC BOUTONS GLOBAUX -->
                    <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                        <!-- Icône avec dégradé -->
                        <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom, #fff7ed, #ffedd5); -fx-background-radius: 18; -fx-min-width: 70; -fx-min-height: 70; -fx-effect: dropshadow(gaussian, rgba(255,140,66,0.2), 10, 0, 0, 2);">
                            <Label style="-fx-font-size: 36;" text="🗺" />
                        </VBox>

                        <!-- Stats Info -->
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Mes Itinéraires" />
                                <Label fx:id="lblTotalItinerairesTable" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 12; -fx-font-size: 12; -fx-font-weight: 600;" text="0 itinéraire" />
                            </HBox>

                            <HBox spacing="24" />
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- BOUTONS GLOBAUX -->
                        <HBox spacing="8">
                            <!-- Badge culturel -->
                            <Label fx:id="cultureBadge" managed="false" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 12; -fx-font-size: 12; -fx-font-weight: 600; -fx-cursor: hand;" text="🌍" visible="false">
                                <tooltip>
                                    <Tooltip text="Conseils culturels disponibles" />
                                </tooltip>
                            </Label>

                            <!-- Bouton vols -->
                            <Button fx:id="btnVols" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12; -fx-cursor: hand;" text="✈ Voir les vols">
                                <tooltip>
                                    <Tooltip text="Rechercher des vols pour cette destination" />
                                </tooltip>
                            </Button>

                            <!-- Bouton conseils culturels -->
                            <Button fx:id="btnCulture" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12; -fx-cursor: hand;" text="🌍 Conseils culturels">
                                <tooltip>
                                    <Tooltip text="Voir les conseils culturels pour cette destination" />
                                </tooltip>
                            </Button>

                            <!-- Quick Actions -->
                            <Button onAction="#handleCreerClick" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: 600; -fx-font-size: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,140,66,0.3), 8, 0, 0, 2);" text="➕ Créer">
                                <tooltip><Tooltip text="Créer un nouvel itinéraire" /></tooltip>
                            </Button>
                        </HBox>
                    </HBox>

                    <!-- BARRE DE RECHERCHE -->
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-background-radius: 50; -fx-padding: 4 4 4 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                        <Label style="-fx-font-size: 16; -fx-text-fill: #94a3b8;" text="🔍" />
                        <TextField fx:id="searchField" promptText="Rechercher un itinéraire par nom, description, voyage ou destination..." style="-fx-background-color: transparent; -fx-pref-width: 500; -fx-font-size: 13; -fx-prompt-text-fill: #94a3b8;" HBox.hgrow="ALWAYS" />

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Bouton de réinitialisation de recherche -->
                        <Button fx:id="btnClearSearch" managed="false" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14; -fx-cursor: hand;" text="✕" visible="false" />
                    </HBox>

                    <!-- FILTERS SECTION -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                        <!-- Titre des filtres -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 14; -fx-text-fill: #ff8c42;" text="⚡" />
                            <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 14;" text="Filtres" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnReinitialiserFiltres" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 12; -fx-cursor: hand; -fx-underline: true;" text="Réinitialiser tout" />
                        </HBox>

                        <!-- Ligne de filtres -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <!-- Destination avec icône -->
                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 4 8 4 12; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                                <Label style="-fx-font-size: 14;" text="📍" />
                                <ComboBox fx:id="comboDestination" promptText="Destination" style="-fx-background-color: transparent; -fx-pref-width: 180;" />
                            </HBox>

                            <!-- Date début avec icône -->
                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 4 8 4 12; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                                <Label style="-fx-font-size: 14;" text="📅" />
                                <DatePicker fx:id="dateDebut" promptText="Date début" style="-fx-background-color: transparent; -fx-pref-width: 140;" />
                            </HBox>

                            <Label style="-fx-font-size: 14; -fx-text-fill: #94a3b8;" text="→" />

                            <!-- Date fin avec icône -->
                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 4 8 4 12; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                                <Label style="-fx-font-size: 14;" text="📅" />
                                <DatePicker fx:id="dateFin" promptText="Date fin" style="-fx-background-color: transparent; -fx-pref-width: 140;" />
                            </HBox>

                            <!-- Tri avec icône -->
                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 4 8 4 12; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                                <Label style="-fx-font-size: 14;" text="🔄" />
                                <ComboBox fx:id="triCombo" promptText="Trier par" style="-fx-background-color: transparent; -fx-pref-width: 180;" />
                            </HBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <!-- Bouton de filtre -->
                            <Button fx:id="btnRechercher" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 30; -fx-padding: 8 24; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,140,66,0.3), 8, 0, 0, 2);" text="Appliquer" />
                        </HBox>
                    </VBox>

                    <!-- LISTE DES ITINÉRAIRES -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">
                        <!-- Header avec titre DYNAMIQUE -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="lblListeTitre" style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Tous les itinéraires" />
                            <Label fx:id="lblResultCount" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 16; -fx-padding: 2 10; -fx-font-size: 12;" text="0" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="8">
                                <Button onAction="#handleExporter" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 30; -fx-padding: 8 20; -fx-font-weight: 600; -fx-font-size: 12; -fx-cursor: hand;" text="📊 Exporter tout">
                                    <tooltip><Tooltip text="Exporter tous les itinéraires" /></tooltip>
                                </Button>
                            </HBox>
                        </HBox>

                        <!-- ITINERARY CARDS CONTAINER -->
                        <VBox fx:id="itinerariesContainer" spacing="15" VBox.vgrow="ALWAYS">
                            <!-- Les cartes seront générées dynamiquement -->
                        </VBox>

                        <!-- Message si aucun itinéraire -->
                        <VBox fx:id="emptyPlaceholder" alignment="CENTER" managed="false" spacing="15" style="-fx-padding: 40 20;" visible="false">
                            <Label style="-fx-font-size: 64; -fx-opacity: 0.5;" text="🗺️" />
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 16; -fx-font-weight: 500;" text="Aucun itinéraire trouvé" />
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" text="Modifiez vos filtres ou créez un nouvel itinéraire" />
                            <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                                <Button fx:id="btnCreerPremierItineraire" onAction="#handleCreerClick" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 30; -fx-padding: 10 24; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand;" text="+ Créer un itinéraire" />
                                <Button onAction="#reinitialiserFiltres" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 30; -fx-padding: 10 24; -fx-font-weight: 600; -fx-font-size: 13; -fx-cursor: hand;" text="Réinitialiser les filtres" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" style="-fx-arc-height: 6; -fx-arc-width: 6;" VBox.vgrow="NEVER" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
