<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="550" prefWidth="600" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ModifierHebergementController">

    <!-- TOP HEADER -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding><Insets bottom="20" left="25" right="25" top="20" /></padding>
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #f59e0b;" text="✏️ Modifier Hébergement" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 10 25;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Dashboard" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Hébergements" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label fx:id="lblBreadcrumb" style="-fx-text-fill: #f59e0b; -fx-font-size: 11; -fx-font-weight: 600;" text="Modification" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent;">
            <content>
                <VBox maxWidth="550" spacing="25">
                    <padding><Insets bottom="30" left="30" right="30" top="25" /></padding>

                    <!-- Header with Icon -->
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox alignment="CENTER" style="-fx-background-color: rgba(245,158,11,0.15); -fx-background-radius: 20; -fx-min-width: 60; -fx-min-height: 60;">
                            <Label style="-fx-font-size: 30;" text="✏️" />
                        </VBox>
                        <VBox spacing="5">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Modifier l'hébergement" />
                            <Label fx:id="lblHebergementName" style="-fx-text-fill: #f59e0b; -fx-font-size: 14; -fx-font-weight: 600;" text="" />
                        </VBox>
                    </HBox>

                    <!-- Hidden ID Field -->
                    <Label fx:id="lblHebergementId" visible="false" managed="false" />

                    <!-- Form Grid -->
                    <GridPane hgap="20" style="-fx-background-color: #111633; -fx-background-radius: 24; -fx-padding: 25; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 24;" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30" />
                            <ColumnConstraints percentWidth="70" />
                        </columnConstraints>

                        <!-- Nom -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Nom *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <TextField fx:id="tfNom" promptText="Ex: Hôtel du Louvre, Villa Méditerranée..." style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" />
                            <Label fx:id="lblNomCounter" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="0/100" />
                        </VBox>

                        <!-- Type -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Type *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cbType" maxWidth="Infinity" promptText="Sélectionner un type" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <!-- Prix par nuit -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Prix/Nuit (€) *" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="tfPrix" promptText="Ex: 120.50" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <!-- Adresse -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Adresse *" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="tfAdresse" promptText="Ex: 10 Rue de Rivoli, Paris" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <!-- Note -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Note (0-5) *" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="tfNote" promptText="Ex: 4.5" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <!-- Destination -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Destination *" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <ComboBox fx:id="cbDestination" maxWidth="Infinity" promptText="Sélectionner une destination" style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <!-- Separator -->
                        <Separator style="-fx-background-color: #1e2749;" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="6" />

                        <!-- Last Modified Info -->
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: rgba(245,158,11,0.1); -fx-background-radius: 12; -fx-padding: 10;" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="7">
                            <Label style="-fx-font-size: 14; -fx-text-fill: #f59e0b;" text="🕒" />
                            <Label fx:id="lblLastModified" style="-fx-text-fill: #f59e0b; -fx-font-size: 11;" text="Modification en cours" />
                        </HBox>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>

                    <!-- Buttons -->
                    <HBox alignment="CENTER" spacing="12">
                        <Button fx:id="btnUpdate" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 40; -fx-background-radius: 12; -fx-cursor: hand;" text="✏️ Mettre à jour" />
                        <Button fx:id="btnCancel" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 40; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;" text="✕ Annuler" />
                    </HBox>

                    <Rectangle arcHeight="8" arcWidth="8" fill="linear-gradient(to right, #f59e0b, #fbbf24)" height="4" width="500">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Rectangle>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>