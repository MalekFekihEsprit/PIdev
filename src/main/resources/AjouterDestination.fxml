<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="600" prefWidth="550" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterDestinationController">

    <!-- TOP HEADER -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding><Insets bottom="20" left="25" right="25" top="20" /></padding>
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #10b981;" text="➕ Ajouter" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 10 25;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Dashboard" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Destinations" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #10b981; -fx-font-size: 11; -fx-font-weight: 600;" text="Nouvelle destination" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent;">
            <content>
                <VBox maxWidth="500" spacing="25">
                    <padding><Insets bottom="30" left="30" right="30" top="25" /></padding>

                    <!-- Header with Icon -->
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox alignment="CENTER" style="-fx-background-color: rgba(16,185,129,0.15); -fx-background-radius: 20; -fx-min-width: 60; -fx-min-height: 60;">
                            <Label style="-fx-font-size: 30;" text="➕" />
                        </VBox>
                        <VBox spacing="5">
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Nouvelle destination" />
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Remplissez tous les champs obligatoires (*)" />
                        </VBox>
                    </HBox>

                    <!-- Form Grid -->
                    <GridPane hgap="20" style="-fx-background-color: #111633; -fx-background-radius: 24; -fx-padding: 25; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 24;" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30" />
                            <ColumnConstraints percentWidth="70" />
                        </columnConstraints>

                        <!-- Pays -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Pays *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <TextField fx:id="tfPays" promptText="Ex: France, Tunisie, Italie..." style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" />
                            <Label fx:id="lblPaysCounter" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="0/30" />
                        </VBox>

                        <!-- Ville with Search Button -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Ville *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="5">
                                <TextField fx:id="tfNom" promptText="Saisissez une ville..." HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-padding: 10 15; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" />
                                <Button fx:id="btnSearchCity" text="🔍" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 12; -fx-min-width: 40; -fx-cursor: hand;" />
                            </HBox>
                            <ComboBox fx:id="cbCitySuggestions" visible="false" managed="false"
                                      promptText="Suggestions..." maxWidth="Infinity"
                                      style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" />
                            <Label fx:id="lblCityValidation" style="-fx-text-fill: #f59e0b; -fx-font-size: 10;" text="" />
                        </VBox>

                        <!-- Description -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <TextArea fx:id="taDescription" prefRowCount="3" promptText="Description détaillée..." style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10;" wrapText="true" />
                            <Label fx:id="lblDescCounter" alignment="CENTER_RIGHT" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="0/1000" />
                        </VBox>

                        <!-- Climat -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Climat *" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ComboBox fx:id="cbClimat" maxWidth="Infinity" promptText="Sélectionner un climat"
                                  style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;"
                                  GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <!-- Saison with Season Detection Button -->
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-font-weight: 500;" text="Saison idéale *" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <HBox spacing="5">
                                <ComboBox fx:id="cbSaison" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                          promptText="Sélectionner une saison"
                                          style="-fx-background-color: #1e2749; -fx-text-fill: white; -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12;" />
                                <Button fx:id="btnDetectSeason" text="🌤️"
                                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 12; -fx-min-width: 40; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <!-- Separator -->
                        <Separator style="-fx-background-color: #1e2749;" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="5" />

                        <!-- Validation Rules -->
                        <GridPane hgap="10" vgap="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="6">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #10b981;" text="✓" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Ville: 2-30 caractères" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #10b981;" text="✓" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Pays: 2-30 caractères" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #10b981;" text="✓" />
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Description: max 1000 caractères" />
                            </HBox>
                        </GridPane>
                    </GridPane>

                    <!-- Uniqueness Warning -->
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(239,68,68,0.1); -fx-background-radius: 12; -fx-padding: 10;">
                        <Label style="-fx-font-size: 14; -fx-text-fill: #ef4444;" text="⚠️" />
                        <Label fx:id="lblUniquenessWarning" style="-fx-text-fill: #ef4444; -fx-font-size: 11; -fx-font-weight: 600;" text="" wrapText="true" />
                    </HBox>

                    <!-- Buttons -->
                    <HBox alignment="CENTER" spacing="12">
                        <Button fx:id="btnSave" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 40; -fx-background-radius: 12; -fx-cursor: hand;" text="💾 Ajouter" />
                        <Button fx:id="btnCancel" style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 40; -fx-background-radius: 12; -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;" text="✕ Annuler" />
                    </HBox>

                    <Rectangle arcHeight="8" arcWidth="8" fill="linear-gradient(to right, #10b981, #34d399)" height="4" width="450">
                        <VBox.margin><Insets top="10" /></VBox.margin>
                    </Rectangle>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>