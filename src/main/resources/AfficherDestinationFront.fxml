<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="1000" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AfficherDestinationfrontController">

    <!-- TOP NAV - SIMPLE HEADER -->
    <top>
        <VBox>
            <!-- Header Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="20" left="32" right="32" top="20" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Close Button -->
                <HBox fx:id="btnClose" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="✕" />
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 12 32;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Destinations" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label fx:id="lblBreadcrumbDestination" style="-fx-text-fill: #ff8c42; -fx-font-size: 12; -fx-font-weight: 600;" text="Détails de la destination" />
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox maxWidth="1000" spacing="30" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="40" left="40" right="40" top="30" />
                    </padding>

                    <!-- HEADER WITH DESTINATION NAME AND ICON -->
                    <HBox alignment="CENTER_LEFT" spacing="24">
                        <!-- Large Icon -->
                        <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 30; -fx-min-width: 100; -fx-min-height: 100; -fx-effect: dropshadow(three-pass-box, rgba(255,140,66,0.2), 15, 0, 0, 5);">
                            <Label fx:id="lblDestinationIcon" style="-fx-font-size: 56;" text="🗼" />
                        </VBox>

                        <!-- Name and Location -->
                        <VBox spacing="8">
                            <Label fx:id="lblDestinationName" style="-fx-font-family: 'Clash Display'; -fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Paris" />
                            <HBox spacing="16">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label style="-fx-font-size: 16;" text="📍" />
                                    <Label fx:id="lblDestinationCountry" style="-fx-text-fill: #475569; -fx-font-size: 18;" text="France" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label style="-fx-font-size: 16;" text="⭐" />
                                    <Label fx:id="lblDestinationScore" style="-fx-text-fill: #f59e0b; -fx-font-size: 18; -fx-font-weight: 600;" text="4.8" />
                                </HBox>
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>

                    <!-- CLIMATE AND SEASON QUICK INFO -->
                    <HBox spacing="20">
                        <!-- Climate Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2); -fx-border-color: #ff8c42; -fx-border-width: 0 0 0 4; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🌡️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="CLIMAT" />
                                    <Label fx:id="lblClimate" style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Méditerranéen" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Season Card -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2); -fx-border-color: #3b82f6; -fx-border-width: 0 0 0 4; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox alignment="CENTER" style="-fx-background-color: #eff6ff; -fx-background-radius: 14; -fx-min-width: 48; -fx-min-height: 48;">
                                    <Label style="-fx-font-size: 24;" text="🗓️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: 500;" text="SAISON IDÉALE" />
                                    <Label fx:id="lblSeason" style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Printemps" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- DESCRIPTION SECTION - TAKES ALL REMAINING SPACE -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 28; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 24;" text="📝" />
                            <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Description et Itinéraire" />
                        </HBox>
                        <Separator style="-fx-background-color: #e2e8f0;" />
                        <!-- TextArea that takes all available space -->
                        <TextArea fx:id="taDescription" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: transparent; -fx-text-fill: #334155; -fx-font-size: 15; -fx-control-inner-background: white; -fx-highlight-fill: #ff8c42;"
                                  prefHeight="600" minHeight="300" maxHeight="Infinity" />
                    </VBox>

                    <!-- COORDINATES AND MAP PREVIEW SECTION -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>

                        <!-- Coordinates Card -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" GridPane.columnIndex="0">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size: 24;" text="📍" />
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Coordonnées" />
                            </HBox>
                            <Separator style="-fx-background-color: #e2e8f0;" />
                            <VBox spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label style="-fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-size: 14; -fx-min-width: 80;" text="Latitude:" />
                                    <Label fx:id="lblLatitude" style="-fx-font-family: 'Clash Display'; -fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 16;" text="48.8566° N" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label style="-fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-size: 14; -fx-min-width: 80;" text="Longitude:" />
                                    <Label fx:id="lblLongitude" style="-fx-font-family: 'Clash Display'; -fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 16;" text="2.3522° E" />
                                </HBox>
                            </VBox>

                            <!-- Mini Map Preview (simulated) -->
                            <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 16;">
                                <Label style="-fx-font-size: 48;" text="🗺️" />
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 12;" text="Aperçu carte" />
                            </VBox>
                        </VBox>

                        <!-- Statistics Card -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);" GridPane.columnIndex="1">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size: 24;" text="📊" />
                                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Statistiques" />
                            </HBox>
                            <Separator style="-fx-background-color: #e2e8f0;" />

                            <!-- Score with progress -->
                            <VBox spacing="8">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 20;" text="⭐" />
                                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 14;" text="Score de popularité" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblScoreValue" style="-fx-font-weight: 700; -fx-text-fill: #f59e0b; -fx-font-size: 18;" text="4.8/5" />
                                </HBox>
                                <ProgressBar fx:id="scoreProgress" prefWidth="200" progress="0.96" style="-fx-accent: #f59e0b; -fx-background-color: #e2e8f0;" />
                            </VBox>

                            <Separator style="-fx-background-color: #e2e8f0;" />

                            <!-- Quick Stats with ID included -->
                            <GridPane hgap="10" vgap="15">
                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Climat:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <Label fx:id="lblStatClimate" style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Méditerranéen" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Saison:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <Label fx:id="lblStatSeason" style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Printemps" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Pays:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <Label fx:id="lblStatCountry" style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="France" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <Label fx:id="lblStatId" style="-fx-font-weight: 600; -fx-text-fill: #3b82f6; -fx-font-size: 13;" text="#1" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <columnConstraints>
                                    <ColumnConstraints halignment="LEFT" />
                                    <ColumnConstraints halignment="RIGHT" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                    <RowConstraints />
                                </rowConstraints>
                            </GridPane>
                        </VBox>
                    </GridPane>

                    <!-- TAGS / HIGHLIGHTS -->
                    <HBox alignment="CENTER" spacing="12">
                        <Label fx:id="lblTagCountry" style="-fx-background-color: #fff7ed; -fx-text-fill: #ff8c42; -fx-background-radius: 20; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12;" text="🇫🇷 France" />
                        <Label fx:id="lblTagClimate" style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-background-radius: 20; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12;" text="🌡️ Méditerranéen" />
                        <Label fx:id="lblTagSeason" style="-fx-background-color: #e6f7e6; -fx-text-fill: #10b981; -fx-background-radius: 20; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12;" text="🗓️ Printemps" />
                        <Label fx:id="lblTagScore" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444; -fx-background-radius: 20; -fx-padding: 8 16; -fx-font-weight: 600; -fx-font-size: 12;" text="⭐ 4.8" />
                    </HBox>

                    <!-- ACTION BUTTONS -->
                    <HBox alignment="CENTER" spacing="12">
                        <!-- Voir Hébergements Button -->
                        <Button fx:id="btnVoirHebergements" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 30; -fx-background-radius: 12; -fx-cursor: hand;" text="🏨 Voir Hébergements" />

                        <!-- Fermer Button -->
                        <Button fx:id="btnClose2" style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14; -fx-padding: 12 30; -fx-background-radius: 12; -fx-cursor: hand;" text="Fermer" />
                    </HBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="8" arcWidth="8" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" width="900">
                        <VBox.margin>
                            <Insets top="10" />
                        </VBox.margin>
                    </Rectangle>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>