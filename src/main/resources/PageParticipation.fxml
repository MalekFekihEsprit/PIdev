<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="750" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ParticipationController">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- TOP NAVIGATION BAR                                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                <padding>
                    <Insets bottom="12" left="24" right="24" top="12" />
                </padding>

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 10; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- Navigation Menu - TOUS LES BOUTONS -->
                <HBox alignment="CENTER_LEFT" spacing="4" style="-fx-padding: 0 0 0 20;">

                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Hébergements -->
                    <HBox fx:id="btnHebergement" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏨" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Hébergements" />
                    </HBox>



                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Catégories -->
                    <HBox fx:id="btnCategories" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="📑" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Catégories" />
                    </HBox>

                    <!-- Voyages (ACTIF) -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="6" style="-fx-background-color: rgba(255,140,66,0.08); -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand; -fx-border-color: rgba(255,140,66,0.5); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14;" text="✈️" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 700; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 14; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-background-radius: 50; -fx-min-width: 38; -fx-min-height: 38; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 50;">
                    <Label style="-fx-font-size: 15;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #f8fafc; -fx-background-radius: 25; -fx-padding: 5 14 5 5; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 25;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="15" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #94a3b8; -fx-font-size: 9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 8;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0; -fx-padding: 8 24;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11; -fx-cursor: hand;" text="✈️ Voyages" onMouseClicked="#retourVoyages" />
                <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 700;" text="👥 Participants" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- BOTTOM STATUS BAR                                         -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 24;">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Circle fill="#10b981" radius="3.5" />
                <Label style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 600;" text="Connecté" />
            </HBox>
            <Rectangle fill="#e2e8f0" height="12" width="1" />
            <Label fx:id="lblTotalParticipantsFooter" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="0 participants" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="© 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT - PAGE PARTICIPANTS                          -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox maxWidth="1100" spacing="20">
                    <padding>
                        <Insets bottom="40" left="30" right="30" top="24" />
                    </padding>

                    <!-- VOYAGE HEADER SECTION -->
                    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 12, 0, 0, 3); -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;">
                        <!-- Orange top accent -->
                        <Rectangle fill="linear-gradient(to right, #ff8c42, #ff6b4a)" height="4" width="2000" arcHeight="4" arcWidth="4" />
                        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 18 24;">
                            <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #fff7ed, #ffedd5); -fx-background-radius: 18; -fx-min-width: 72; -fx-min-height: 72; -fx-border-color: rgba(255,140,66,0.15); -fx-border-width: 1; -fx-border-radius: 18;">
                                <Label style="-fx-font-size: 36;" text="👥" />
                            </VBox>
                            <VBox spacing="6">
                                <Label fx:id="lblTitreVoyage" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                                <HBox spacing="20">
                                    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-padding: 4 10;">
                                        <Label text="📍" style="-fx-font-size: 13;" />
                                        <Label fx:id="lblDestinationVoyage" style="-fx-text-fill: #475569; -fx-font-size: 13; -fx-font-weight: 500;" />
                                    </HBox>
                                    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-padding: 4 10;">
                                        <Label text="📅" style="-fx-font-size: 13;" />
                                        <Label fx:id="lblDatesVoyage" style="-fx-text-fill: #475569; -fx-font-size: 13; -fx-font-weight: 500;" />
                                    </HBox>
                                </HBox>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#retourVoyages"
                                    style="-fx-background-color: #f8fafc; -fx-text-fill: #475569; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-font-size: 12;"
                                    text="← Retour aux voyages" />
                        </HBox>
                    </VBox>

                    <!-- ADD PARTICIPANT FORM -->
                    <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 12, 0, 0, 3); -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: #0f172a;" text="➕ Ajouter un participant par email" />
                            <Rectangle fill="#ff8c42" height="2" width="40" />
                        </HBox>

                        <GridPane hgap="16" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="45" />
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="20" />
                            </columnConstraints>

                            <!-- Email -->
                            <VBox spacing="6" GridPane.columnIndex="0">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="📧 Email de l'utilisateur" />
                                <TextField fx:id="tfEmail" promptText="exemple@email.com"
                                           style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-border-width: 1;"
                                           prefHeight="38" />
                            </VBox>

                            <!-- Role -->
                            <VBox spacing="6" GridPane.columnIndex="1">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 11; -fx-font-weight: 600;" text="🏷️ Rôle" />
                                <ComboBox fx:id="cbRole" promptText="Sélectionner un rôle"
                                          style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 4;"
                                          prefHeight="38" />
                            </VBox>

                            <!-- Button -->
                            <VBox alignment="BOTTOM_CENTER" GridPane.columnIndex="2">
                                <Button fx:id="btnAjouterParticipation" onAction="#ajouterParticipation"
                                        style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 24; -fx-font-weight: 700; -fx-cursor: hand; -fx-font-size: 12;"
                                        text="+ Ajouter" prefHeight="38" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- PARTICIPANTS TABLE SECTION -->
                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 12, 0, 0, 3); -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 20;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-min-width: 38; -fx-min-height: 38;">
                                <Label style="-fx-font-size: 17; -fx-text-fill: white;" text="📋" />
                            </VBox>
                            <Label style="-fx-font-size: 18; -fx-font-weight: 700; -fx-text-fill: #0f172a;" text="Liste des participants" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblTotalParticipants"
                                   style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 16; -fx-font-weight: 700; -fx-font-size: 11;"
                                   text="0 participants" />
                        </HBox>

                        <!-- Table -->
                        <TableView fx:id="tableParticipations" prefHeight="300"
                                   style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14;">
                            <columns>
                                <TableColumn fx:id="colEmail" prefWidth="250" text="Email" />
                                <TableColumn fx:id="colNom" prefWidth="150" text="Nom" />
                                <TableColumn fx:id="colPrenom" prefWidth="150" text="Prénom" />
                                <TableColumn fx:id="colRole" prefWidth="150" text="Rôle" />
                                <TableColumn fx:id="colActions" prefWidth="150" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="10">
                                    <Label style="-fx-font-size: 32;" text="👥" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="Aucun participant pour le moment" />
                                    <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 10;" text="Ajoutez un participant via le formulaire ci-dessus" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- Bottom Decoration -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" width="1100">
                        <VBox.margin>
                            <Insets top="10" />
                        </VBox.margin>
                    </Rectangle>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>