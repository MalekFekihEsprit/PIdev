<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="750" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="Controllers.ParticipationController">

    <!-- TOP NAV -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="15" left="20" right="20" top="15" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="8">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="14" />
                    <Label style="-fx-font-family: 'System'; -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 3 8; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU -->
                <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0 0 0 15;">
                    <!-- Destinations -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Itinéraires -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🗺️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Itinéraires" />
                    </HBox>

                    <!-- Activités -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="✈️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search bar -->
                <HBox alignment="CENTER" spacing="6" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 6 16;">
                    <Label style="-fx-font-size: 12;" text="🔍" />
                </HBox>

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 35; -fx-min-height: 35; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 14;" text="🔔" />
                </HBox>

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-background-radius: 25; -fx-padding: 4 12 4 4; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="14" />
                    <VBox spacing="0">
                        <Label style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Minyar GHANNEM" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 8 20;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11; -fx-cursor: hand;" text="Voyages" onMouseClicked="#retourVoyages" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 600;" text="Participants" />
            </HBox>
        </VBox>
    </top>

    <!-- BOTTOM STATUS -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 8 20;">
            <Label style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 500;" text="● Connecté" />
            <Label fx:id="lblTotalParticipantsFooter" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="0 participants" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Dernière mise à jour: 15 Fév 2026" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #f8fafc; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox maxWidth="1100" spacing="24">
                    <padding>
                        <Insets bottom="40" left="30" right="30" top="30" />
                    </padding>

                    <!-- EN-TÊTE DU VOYAGE -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 20;">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 16; -fx-min-width: 70; -fx-min-height: 70;">
                                <Label style="-fx-font-size: 36;" text="👥" />
                            </VBox>
                            <VBox spacing="4">
                                <Label fx:id="lblTitreVoyage" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                                <HBox spacing="20">
                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                        <Label text="📍" style="-fx-font-size: 14;" />
                                        <Label fx:id="lblDestinationVoyage" style="-fx-text-fill: #64748b; -fx-font-size: 14;" />
                                    </HBox>
                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                        <Label text="📅" style="-fx-font-size: 14;" />
                                        <Label fx:id="lblDatesVoyage" style="-fx-text-fill: #64748b; -fx-font-size: 14;" />
                                    </HBox>
                                </HBox>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#retourVoyages" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 10 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none;" text="← Retour aux voyages" />
                        </HBox>
                    </VBox>

                    <!-- FORMULAIRE D'AJOUT -->
                    <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 20;">
                        <Label style="-fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Ajouter un participant par email" />

                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="45" />
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="20" />
                            </columnConstraints>

                            <!-- Email -->
                            <VBox spacing="4" GridPane.columnIndex="0">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: 600;" text="Email de l'utilisateur" />
                                <TextField fx:id="tfEmail" promptText="exemple@email.com" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-font-size: 13;" prefHeight="35" />
                            </VBox>

                            <!-- Rôle -->
                            <VBox spacing="4" GridPane.columnIndex="1">
                                <Label style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: 600;" text="Rôle" />
                                <ComboBox fx:id="cbRole" promptText="Sélectionner un rôle" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10; -fx-padding: 8; -fx-font-size: 13;" prefHeight="35" />
                            </VBox>

                            <!-- Bouton -->
                            <VBox alignment="BOTTOM_RIGHT" GridPane.columnIndex="2">
                                <Button fx:id="btnAjouterParticipation" onAction="#ajouterParticipation" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 20; -fx-font-weight: 600; -fx-cursor: hand; -fx-border: none; -fx-font-size: 13;" text="+ Ajouter" prefHeight="35" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- LISTE DES PARTICIPANTS -->
                    <VBox spacing="15">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 20; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Liste des participants" />
                            <Label fx:id="lblTotalParticipants" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 12; -fx-font-weight: 600; -fx-font-size: 12;" text="0 participants" />
                        </HBox>

                        <!-- Tableau des participations -->
                        <TableView fx:id="tableParticipations" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e2e8f0; -fx-border-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                            <columns>
                                <TableColumn fx:id="colEmail" prefWidth="250" text="Email" />
                                <TableColumn fx:id="colNom" prefWidth="150" text="Nom" />
                                <TableColumn fx:id="colPrenom" prefWidth="150" text="Prénom" />
                                <TableColumn fx:id="colRole" prefWidth="150" text="Rôle" />
                                <TableColumn fx:id="colActions" prefWidth="150" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" width="1100">
                        <VBox.margin>
                            <Insets top="20" />
                        </VBox.margin>
                    </Rectangle>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>