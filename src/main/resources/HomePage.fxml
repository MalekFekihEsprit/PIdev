<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.HomePageController">

    <!-- Top Banner -->
    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 30 0 20 0;">
                <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="30" />
                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 12; -fx-font-weight: bold;" text="PRO" />
            </HBox>
        </VBox>
    </top>

    <!-- Center Content -->
    <center>
        <VBox alignment="CENTER" spacing="40" style="-fx-padding: 40;">

            <!-- Welcome Message -->
            <VBox alignment="CENTER" spacing="10">
                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 32; -fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Bienvenue sur TravelMate" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 16;" text="Choisissez l'interface que vous souhaitez utiliser" />
            </VBox>

            <!-- Choice Cards -->
            <HBox alignment="CENTER" spacing="30">

                <!-- Front Office Card -->
                <VBox fx:id="frontOfficeCard" alignment="CENTER" prefWidth="300" spacing="20" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 20, 0, 0, 10); -fx-cursor: hand;">
                    <Label style="-fx-font-size: 64;" text="🌍" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Front Office" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 14; -fx-alignment: center;" text="Explorez les destinations et découvrez tous les lieux de voyage" wrapText="true" />

                    <Rectangle arcHeight="4" arcWidth="4" fill="linear-gradient(to right, #ff8c42, #ff6b4a)" height="4" width="100">
                        <VBox.margin>
                            <Insets top="10" />
                        </VBox.margin>
                    </Rectangle>
                </VBox>

                <!-- Back Office Card -->
                <VBox fx:id="backOfficeCard" alignment="CENTER" prefWidth="300" spacing="20" style="-fx-background-color: #111633; -fx-background-radius: 30; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 10); -fx-cursor: hand;">
                    <Label style="-fx-font-size: 64;" text="⚙️" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Back Office" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14; -fx-alignment: center;" text="Administrez les destinations et gérez la base de données" wrapText="true" />

                    <Rectangle arcHeight="4" arcWidth="4" fill="linear-gradient(to right, #ff8c42, #ff6b4a)" height="4" width="100">
                        <VBox.margin>
                            <Insets top="10" />
                        </VBox.margin>
                    </Rectangle>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <!-- Bottom Status -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 15;">
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="©️ 2026 TravelMate - Tous droits réservés" />
        </HBox>
    </bottom>

</BorderPane>
