<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlles.PageEtape"
            style="-fx-background-color: linear-gradient(to bottom right, #f0f4f8, #e6eef5);">

    <!-- Header -->
    <top>
        <VBox styleClass="main-header" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="📋" style="-fx-font-size: 32px;"/>
                <VBox spacing="5">
                    <Label text="Gestion des Étapes" styleClass="header-title"/>
                    <Label text="Planifiez et organisez vos activités étape par étape" styleClass="header-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Nouvelle étape" styleClass="btn-success"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Filtrer par :" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <ChoiceBox prefWidth="180" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 3;"/>
                <DatePicker promptText="Date" style="-fx-background-color: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="Rechercher une étape..." prefWidth="250" styleClass="search-field"/>
            </HBox>
        </VBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="20" style="-fx-background-color: transparent; -fx-padding: 30;">

                <!-- Jour 1 -->
                <VBox styleClass="jour-container">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="1" styleClass="jour-number"/>
                        <VBox>
                            <Label text="Jour 1" styleClass="jour-title"/>
                            <Label text="Découverte du centre historique" styleClass="jour-description"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Mère du jour" styleClass="status-badge, status-warning"/>
                    </HBox>

                    <Separator styleClass="separator"/>

                    <VBox spacing="15">
                        <!-- Étape 1 -->
                        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="etape-item">
                            <Label text="08:00" styleClass="etape-time"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Petit-déjeuner à la place principale" styleClass="etape-title"/>
                                <Label text="Café traditionnel et pâtisseries locales" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                                <HBox styleClass="etape-meta">
                                    <Label text="⏱️ 1h" styleClass="etape-duree"/>
                                    <Label text="💰 15€" styleClass="etape-budget"/>
                                    <Label text="📍 Centre ville" styleClass="etape-lieu"/>
                                </HBox>
                            </VBox>
                            <HBox spacing="10">
                                <Button text="Modifier" styleClass="btn-gray, btn-small"/>
                                <Button text="Supprimer" styleClass="btn-danger, btn-small"/>
                            </HBox>
                        </HBox>

                        <!-- Étape 2 -->
                        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="etape-item">
                            <Label text="10:30" styleClass="etape-time"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Visite du musée d'art moderne" styleClass="etape-title"/>
                                <Label text="Collection permanente et exposition temporaire" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                                <HBox styleClass="etape-meta">
                                    <Label text="⏱️ 2h" styleClass="etape-duree"/>
                                    <Label text="💰 12€" styleClass="etape-budget"/>
                                    <Label text="📍 Rue du Musée" styleClass="etape-lieu"/>
                                    <Label text="⭐ Difficulté: Facile" styleClass="etape-difficulte"/>
                                </HBox>
                            </VBox>
                            <HBox spacing="10">
                                <Button text="Modifier" styleClass="btn-gray, btn-small"/>
                                <Button text="Supprimer" styleClass="btn-danger, btn-small"/>
                            </HBox>
                        </HBox>

                        <!-- Étape 3 -->
                        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="etape-item">
                            <Label text="14:00" styleClass="etape-time"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Déjeuner au marché couvert" styleClass="etape-title"/>
                                <Label text="Spécialités régionales et produits frais" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
                                <HBox styleClass="etape-meta">
                                    <Label text="⏱️ 1h30" styleClass="etape-duree"/>
                                    <Label text="💰 25€" styleClass="etape-budget"/>
                                    <Label text="📍 Marché central" styleClass="etape-lieu"/>
                                </HBox>
                            </VBox>
                            <HBox spacing="10">
                                <Button text="Modifier" styleClass="btn-gray, btn-small"/>
                                <Button text="Supprimer" styleClass="btn-danger, btn-small"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Ajouter une étape" styleClass="btn-success"/>
                        <Button text="Voir carte" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

                <!-- Jour 2 -->
                <VBox styleClass="jour-container">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="2" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-size: 18px;"/>
                        <VBox>
                            <Label text="Jour 2" styleClass="jour-title"/>
                            <Label text="Aventure et nature" styleClass="jour-description"/>
                        </VBox>
                    </HBox>

                    <Separator styleClass="separator"/>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 30 0;">
                        <Label text="Aucune étape planifiée pour ce jour" style="-fx-text-fill: #95a5a6; -fx-font-style: italic;"/>
                        <Button text="+ Ajouter" styleClass="btn-primary, btn-small"/>
                    </HBox>
                </VBox>

                <!-- Jour 3 -->
                <VBox styleClass="jour-container">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="3" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-size: 18px;"/>
                        <VBox>
                            <Label text="Jour 3" styleClass="jour-title"/>
                            <Label text="Détente et shopping" styleClass="jour-description"/>
                        </VBox>
                    </HBox>

                    <Separator styleClass="separator"/>

                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 30 0;">
                        <Label text="Aucune étape planifiée pour ce jour" style="-fx-text-fill: #95a5a6; -fx-font-style: italic;"/>
                        <Button text="+ Ajouter" styleClass="btn-primary, btn-small"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox styleClass="footer">
            <Label text="Total: 3 étapes" styleClass="footer-total"/>
            <Label text="•" style="-fx-text-fill: #bdc3c7;"/>
            <Label text="Durée totale: 4h30" styleClass="footer-info"/>
        </HBox>
    </bottom>
</BorderPane>