<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="750.0" prefWidth="950.0" style="-fx-background-color: #F4F7F6;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlles.PageEtape">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="30.0"
              style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets top="15.0" right="20.0" bottom="15.0" left="20.0"/>
            </padding>
            <children>
                <Button fx:id="btnRetour" mnemonicParsing="false" text="←"
                        style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Label text="Accueil" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2d3436;"/>
                <Label text="Mes Voyages" style="-fx-font-size: 16px; -fx-text-fill: #636e72;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Circle fill="#dfe6e9" radius="20.0" stroke="#bdc3c7" strokeType="INSIDE"/>
            </children>
        </HBox>

        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="65.0">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
            </padding>
            <children>
                <VBox spacing="10.0">
                    <children>
                        <AnchorPane prefHeight="250.0"
                                   style="-fx-border-color: #e67e22; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-color: #ecf0f1;">
                            <children>
                                <Label layoutX="320.0" layoutY="110.0" text="ZONE CARTE INTERACTIVE"
                                       style="-fx-font-size: 18px; -fx-font-style: italic; -fx-text-fill: #95a5a6;"/>
                                <Button fx:id="btnAjouterEtape" mnemonicParsing="false" text="+ Ajouter étape"
                                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-weight: bold;"
                                        AnchorPane.bottomAnchor="15.0" AnchorPane.rightAnchor="15.0">
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                </Button>
                            </children>
                        </AnchorPane>
                        <Label text="Les étapes du jour sélectionné :"
                               style="-fx-font-size: 15px; -fx-font-style: italic; -fx-text-fill: #2980b9;"/>
                    </children>
                </VBox>

                <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                    <children>
                        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <VBox fx:id="listeEtapesContainer" spacing="15.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0"
                                              style="-fx-background-color: white; -fx-border-color: #e67e22; -fx-border-radius: 15; -fx-background-radius: 15;">
                                            <padding>
                                                <Insets left="20.0" right="20.0"/>
                                            </padding>
                                            <children>
                                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Étape 1 :" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #d35400;"/>
                                                    </children>
                                                </VBox>
                                                <Button mnemonicParsing="false" text="✏️" style="-fx-background-color: #f1f2f6; -fx-cursor: hand;"/>
                                                <Button mnemonicParsing="false" text="🗑️" style="-fx-background-color: #f1f2f6; -fx-cursor: hand;"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0"
                                              style="-fx-background-color: white; -fx-border-color: #e67e22; -fx-border-radius: 15; -fx-background-radius: 15;">
                                            <padding>
                                                <Insets left="20.0" right="20.0"/>
                                            </padding>
                                            <children>
                                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Étape 2 :" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #d35400;"/>
                                                    </children>
                                                </VBox>
                                                <Button mnemonicParsing="false" text="✏️" style="-fx-background-color: #f1f2f6; -fx-cursor: hand;"/>
                                                <Button mnemonicParsing="false" text="🗑️" style="-fx-background-color: #f1f2f6; -fx-cursor: hand;"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <VBox alignment="CENTER" prefWidth="200.0" spacing="25.0">
                            <children>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <Button fx:id="btnModifier" prefHeight="60.0" prefWidth="60.0" mnemonicParsing="false" text="✏️"
                                            style="-fx-background-color: white; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 20px; -fx-cursor: hand;"/>
                                    <Label text="Modifier" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #e74c3c;"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <Button fx:id="btnSupprimer" prefHeight="60.0" prefWidth="60.0" mnemonicParsing="false" text="🗑️"
                                            style="-fx-background-color: white; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 20px; -fx-cursor: hand;"/>
                                    <Label text="Supprimer" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #e74c3c;"/>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
