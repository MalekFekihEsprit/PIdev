<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controlles.CATfront"
            stylesheets="@categoriesfront.css"
            prefHeight="900" prefWidth="1400" style="-fx-background-color: #0a0e27;">

    <!-- TOP NAVIGATION BAR -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="20" right="32" bottom="20" left="32"/>
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                    <Label text="TravelMate" style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                    <Label text="PRO" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Navigation Menu -->
                <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 20;">
                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="🏠" style="-fx-font-size: 16;"/>
                        <Label text="Accueil" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <!-- Catégories - Active -->
                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="📑" style="-fx-font-size: 16;"/>
                        <Label text="Catégories" style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14;"/>
                    </HBox>

                    <!-- Activités (non actif) -->
                    <HBox spacing="8" alignment="CENTER" fx:id="btnVersActivites" onMouseClicked="#handleVersActivites" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="🎯" style="-fx-font-size: 16;"/>
                        <Label text="Activités" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="✈️" style="-fx-font-size: 16;"/>
                        <Label text="Voyages" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label text="💰" style="-fx-font-size: 16;"/>
                        <Label text="Budgets" style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;"/>
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Bouton Back Office -->
                <Button fx:id="btnBackOffice" text="⚙️ Back Office" onAction="#handleBackOffice"
                        style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: 600;
                               -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 12;
                               -fx-border-color: #818cf8; -fx-border-width: 1; -fx-border-radius: 20;"/>

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16"/>
                    <VBox spacing="0">
                        <Label text="Yosr Boutaieb" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 13;"/>
                        <Label text="Utilisateur" style="-fx-text-fill: #64748b; -fx-font-size: 10;"/>
                    </VBox>
                    <Label text="▼" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;"/>
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #0a0e27; -fx-padding: 8 32;">
                <Label text="Accueil" style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-cursor: hand;"/>
                <Label text=">" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
                <Label text="Catégories" style="-fx-text-fill: #ff8c42; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #0a0e27; -fx-padding: 32;">

            <!-- Page Header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="📑" style="-fx-font-size: 28;"/>
                <Label text="Explorez les Catégories" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Statistics -->
                <HBox spacing="20">
                    <VBox spacing="4" alignment="CENTER" style="-fx-background-color: #111633; -fx-background-radius: 15; -fx-padding: 15 25; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 15;">
                        <Label fx:id="lblTotalCategories" text="0" style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ff8c42;"/>
                        <Label text="Catégories Totales" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Filtres -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Filtrer par:" style="-fx-text-fill: #94a3b8; -fx-font-size: 14; -fx-font-weight: bold;"/>

                <VBox spacing="5">
                    <Label text="Type" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                    <ComboBox fx:id="filterTypeCombo" prefWidth="150" style="-fx-background-color: #1e2749; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Saison" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                    <ComboBox fx:id="filterSaisonCombo" prefWidth="150" style="-fx-background-color: #1e2749; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Intensité" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                    <ComboBox fx:id="filterIntensiteCombo" prefWidth="150" style="-fx-background-color: #1e2749; -fx-text-fill: white;"/>
                </VBox>

                <Button text="↺ Réinitialiser" onAction="#handleResetFilters"
                        style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8;
                               -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;
                               -fx-border-color: #2d3a5f; -fx-border-width: 1; -fx-border-radius: 10;
                               -fx-font-weight: 500; -fx-font-size: 12;"/>
            </HBox>

            <!-- Grille de catégories -->
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <GridPane fx:id="categoriesGrid" hgap="20" vgap="20" style="-fx-padding: 10;">
                    <padding>
                        <Insets bottom="20" right="10"/>
                    </padding>
                </GridPane>
            </ScrollPane>

            <!-- Bottom Gradient -->
            <Rectangle fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" arcHeight="8" arcWidth="8">
                <VBox.margin>
                    <Insets top="20"/>
                </VBox.margin>
            </Rectangle>

        </VBox>
    </center>

</BorderPane>