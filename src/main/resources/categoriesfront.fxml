<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>

<BorderPane prefHeight="900" prefWidth="1400"
            style="-fx-background-color:#f0f4f0;"
            stylesheets="@categoriesfront.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlles.CATfront">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- NAVBAR ORANGE                                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color:#f5a623;-fx-padding:0 30 0 20;-fx-min-height:60;-fx-pref-height:60;">

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:0 30 0 0;">
                    <Circle fill="#ff6b00" radius="14"/>
                    <Label text="TravelMate" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <Label text="PRO" style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:10;-fx-padding:2 8;-fx-font-size:9;-fx-font-weight:bold;"/>
                </HBox>

                <!-- Nav links -->
                <HBox alignment="CENTER" spacing="5">
                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label text="🏠" style="-fx-font-size:13;"/>
                        <Label text="Destinations" style="-fx-text-fill:#1a1a1a;-fx-font-size:13;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label text="🗺" style="-fx-font-size:13;"/>
                        <Label text="Itinémires" style="-fx-text-fill:#1a1a1a;-fx-font-size:13;"/>
                    </HBox>

                    <!-- Catégories - ACTIVE -->
                    <HBox alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:8 18;-fx-cursor:hand;">
                        <Label text="📑" style="-fx-font-size:13;"/>
                        <Label text="Catégories" style="-fx-text-fill:#ff6b00;-fx-font-weight:bold;-fx-font-size:13;"/>
                    </HBox>

                    <!-- Activités - nav -->
                    <HBox fx:id="btnVersActivites" alignment="CENTER" spacing="6"
                          onMouseClicked="#handleVersActivites"
                          style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label text="🎯" style="-fx-font-size:13;"/>
                        <Label text="Activités" style="-fx-text-fill:#1a1a1a;-fx-font-size:13;"/>
                    </HBox>

                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label text="✈" style="-fx-font-size:13;"/>
                        <Label text="Voyages" style="-fx-text-fill:#1a1a1a;-fx-font-size:13;"/>
                    </HBox>

                    <HBox alignment="CENTER" spacing="6"
                          style="-fx-background-color:#ff6b00;-fx-background-radius:20;-fx-padding:8 18;-fx-cursor:hand;">
                        <Label text="💰" style="-fx-font-size:13;"/>
                        <Label text="Budgets" style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13;"/>
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search Bar -->
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:8 16;-fx-min-width:200;">
                    <Label text="🔍" style="-fx-font-size:13;-fx-text-fill:#999;"/>
                    <TextField fx:id="searchField" promptText="Rechercher une catégorie..."
                               style="-fx-background-color: transparent; -fx-text-fill: #1a1a1a; -fx-prompt-text-fill: #aaa; -fx-border-color: transparent; -fx-font-size: 12;"
                               prefWidth="150"/>
                </HBox>

                <HBox alignment="CENTER" style="-fx-padding:0 14;">
                    <Label text="🔔" style="-fx-font-size:18;-fx-text-fill:#1a1a1a;-fx-cursor:hand;"/>
                </HBox>

                <!-- User -->
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:6 0;-fx-cursor:hand;">
                    <Circle fill="#ff6b00" radius="16"/>
                    <VBox spacing="0">
                        <Label text="Yosr Boutaieb" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:12;"/>
                        <Label text="Utilisateur" style="-fx-text-fill:#5a3a00;-fx-font-size:10;"/>
                    </VBox>
                    <Label text="▼" style="-fx-text-fill:#333;-fx-font-size:11;"/>
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="6"
                  style="-fx-background-color:#f0f4f0;-fx-padding:10 30;">
                <Label text="🏠 Accueil" style="-fx-text-fill:#888;-fx-font-size:12;"/>
                <Label text=">" style="-fx-text-fill:#aaa;-fx-font-size:12;"/>
                <Label text="Catégories"
                       style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:4 14;-fx-font-size:12;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblDate" text="📅 Mars 2026" style="-fx-text-fill:#888;-fx-font-size:12;"/>

                <!-- BOUTON DE TRADUCTION -->
                <Button fx:id="btnTranslate" text="🌐 Traduire" onAction="#handleTranslate"
                        style="-fx-background-color:#10b981;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:5 16;-fx-font-size:12;-fx-cursor:hand;-fx-border-width:0;-fx-font-weight:bold;-fx-margin-right:10;"/>

                <!-- Bouton Back Office -->
                <Button fx:id="btnToggleOffice" onAction="#handleToggleOffice"
                        text="⚙ Back Office"
                        style="-fx-background-color:#6366f1;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:5 16;-fx-font-size:12;-fx-cursor:hand;-fx-border-width:0;-fx-font-weight:bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CENTRE                                                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0" style="-fx-background-color:#f0f4f0;-fx-padding:20 30;">

            <!-- ── Panneau gauche ── -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <!-- Header + filtres -->
                <HBox alignment="CENTER_LEFT" spacing="14"
                      style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:18 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label text="📑" style="-fx-font-size:22;-fx-text-fill:#ff6b00;"/>
                    <Label text="Explorez les Catégories"
                           style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="filterTypeCombo" prefWidth="130" promptText="Type"
                              style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;"/>
                    <ComboBox fx:id="filterSaisonCombo" prefWidth="140" promptText="Saison"
                              style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;"/>
                    <ComboBox fx:id="filterIntensiteCombo" prefWidth="130" promptText="Intensité"
                              style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;"/>
                    <Button text="↺" onAction="#handleResetFilters"
                            style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 14;-fx-cursor:hand;-fx-font-size:14;"/>
                </HBox>

                <!-- Stats -->
                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-border-left-width:4;-fx-border-color:#ff6b00 transparent transparent transparent;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="CATÉGORIES TOTALES" style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;"/>
                        <Label fx:id="lblTotalCategories" text="0"
                               style="-fx-font-size:44;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="CATÉGORIE POPULAIRE" style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🏆" style="-fx-font-size:22;"/>
                            <VBox spacing="2">
                                <Label fx:id="lblTopCategorie" text="—"
                                       style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;"/>
                                <Label fx:id="lblTopType" text="—"
                                       style="-fx-text-fill:#888;-fx-font-size:12;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="SAISON DOMINANTE" style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="lblSaisonIcon" text="🌤" style="-fx-font-size:26;"/>
                            <VBox spacing="2">
                                <Label fx:id="lblTopSaison" text="—"
                                       style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;"/>
                                <Label fx:id="lblSaisonCount" text="0 catégories"
                                       style="-fx-text-fill:#888;-fx-font-size:12;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="PUBLIC CIBLE" style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;"/>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="👥" style="-fx-font-size:22;"/>
                            <Label fx:id="lblTopPublic" text="—"
                                   style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:15;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Titre section -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Liste des Catégories"
                           style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <Label text="— cliquez sur une carte pour explorer ses activités"
                           style="-fx-text-fill:#999;-fx-font-size:12;"/>
                </HBox>

                <!-- Grille -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                    <GridPane fx:id="categoriesGrid" hgap="16" vgap="16" style="-fx-padding:4 4 20 4;"/>
                </ScrollPane>
            </VBox>

            <!-- ── Panneau droit ── -->
            <VBox spacing="20" prefWidth="300" style="-fx-padding:0 0 0 24;">

                <!-- PieChart Saison -->
                <VBox spacing="12"
                      style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label text="Répartition par Saison"
                           style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <PieChart fx:id="pieChartSaison" prefHeight="170" prefWidth="260"
                              labelsVisible="false" legendVisible="true"
                              style="-fx-background-color:transparent;"/>
                </VBox>

                <!-- PieChart Type -->
                <VBox spacing="12"
                      style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label text="Répartition par Type"
                           style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <PieChart fx:id="pieChartType" prefHeight="170" prefWidth="260"
                              labelsVisible="false" legendVisible="true"
                              style="-fx-background-color:transparent;"/>
                </VBox>

                <!-- Détail catégorie sélectionnée (lecture seule) -->
                <VBox spacing="10"
                      style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label text="Catégorie sélectionnée"
                           style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#888;"/>
                    <Label fx:id="lblSelectedNom" text="—"
                           style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;"/>
                    <Label fx:id="lblSelectedInfo" text="Cliquez sur une carte"
                           style="-fx-text-fill:#888;-fx-font-size:12;"/>
                    <Label text="ℹ Cliquez sur une carte pour voir le détail."
                           style="-fx-text-fill:#aaa;-fx-font-size:11;"/>
                </VBox>

                <!-- Reset filtres -->
                <Button onAction="#handleResetFilters" text="↺ Réinitialiser les filtres"
                        style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 20;-fx-cursor:hand;-fx-font-size:12;-fx-max-width:Infinity;"/>
            </VBox>
        </HBox>
    </center>

    <!-- Barre de bas -->
    <bottom>
        <Rectangle fill="linear-gradient(to right,#f5a623,#ff6b00,#6366f1)"
                   height="5" width="1400"
                   xmlns="http://javafx.com/javafx/22"/>
    </bottom>

</BorderPane>