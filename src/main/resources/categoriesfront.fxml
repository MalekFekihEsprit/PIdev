<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color:#f0f4f0;" stylesheets="@categoriesfront.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlles.CATfront">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- NAVBAR ORANGE                                              -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color:#f5a623;-fx-padding:0 30 0 20;-fx-min-height:60;-fx-pref-height:60;">

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:0 30 0 0;">
                    <Circle fill="#ff6b00" radius="14" />
                    <Label style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="TravelMate" />
                    <Label style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:10;-fx-padding:2 8;-fx-font-size:9;-fx-font-weight:bold;" text="PRO" />
                </HBox>

                <!-- Nav links -->
                <HBox alignment="CENTER" spacing="5">
                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="🏠" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-size:13;" text="Destinations" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="🗺" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-size:13;" text="Itinéraires" />
                    </HBox>

                    <!-- Catégories - ACTIVE -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:8 18;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="📑" />
                        <Label style="-fx-text-fill:#ff6b00;-fx-font-weight:bold;-fx-font-size:13;" text="Catégories" />
                    </HBox>

                    <!-- Activités - nav -->
                    <HBox fx:id="btnVersActivites" alignment="CENTER" onMouseClicked="#handleVersActivites" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="🎯" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-size:13;" text="Activités" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="✈" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-size:13;" text="Voyages" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color:#ff6b00;-fx-background-radius:20;-fx-padding:8 18;-fx-cursor:hand;">
                        <Label style="-fx-font-size:13;" text="💰" />
                        <Label style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search Bar -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:8 16;-fx-min-width:200;">
                    <Label style="-fx-font-size:13;-fx-text-fill:#999;" text="🔍" />
                    <TextField fx:id="searchField" prefWidth="150" promptText="Rechercher une catégorie..." style="-fx-background-color: transparent; -fx-text-fill: #1a1a1a; -fx-prompt-text-fill: #aaa; -fx-border-color: transparent; -fx-font-size: 12;" />
                </HBox>

                <HBox alignment="CENTER" style="-fx-padding:0 14;">
                    <Label style="-fx-font-size:18;-fx-text-fill:#1a1a1a;-fx-cursor:hand;" text="🔔" />
                </HBox>

                <!-- User -->
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:6 0;-fx-cursor:hand;">
                    <Circle fill="#ff6b00" radius="16" />
                    <VBox spacing="0">
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:12;" text="Yosr Boutaieb" />
                        <Label style="-fx-text-fill:#5a3a00;-fx-font-size:10;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill:#333;-fx-font-size:11;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color:#f0f4f0;-fx-padding:10 30;">
                <Label style="-fx-text-fill:#888;-fx-font-size:12;" text="🏠 Accueil" />
                <Label style="-fx-text-fill:#aaa;-fx-font-size:12;" text="&gt;" />
                <Label style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:4 14;-fx-font-size:12;" text="Catégories" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblDate" style="-fx-text-fill:#888;-fx-font-size:12;" text="📅 Mars 2026" />

                <!-- BOUTON DE TRADUCTION -->
                <Button fx:id="btnTranslate" onAction="#handleTranslate" style="-fx-background-color:#10b981;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:5 16;-fx-font-size:12;-fx-cursor:hand;-fx-border-width:0;-fx-font-weight:bold;-fx-margin-right:10;" text="🌐 Traduire" />

                <!-- Bouton Back Office -->
                <Button fx:id="btnToggleOffice" onAction="#handleToggleOffice" style="-fx-background-color:#6366f1;-fx-text-fill:white;-fx-background-radius:15;-fx-padding:5 16;-fx-font-size:12;-fx-cursor:hand;-fx-border-width:0;-fx-font-weight:bold;" text="⚙ Back Office" />
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CENTRE                                                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0" style="-fx-background-color:#f0f4f0;-fx-padding:20 30;">

            <!-- ── Panneau gauche ── -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <!-- Header + filtres -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:18 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label style="-fx-font-size:22;-fx-text-fill:#ff6b00;" text="📑" />
                    <Label style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Explorez les Catégories" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="filterTypeCombo" prefWidth="130" promptText="Type" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <ComboBox fx:id="filterSaisonCombo" prefWidth="140" promptText="Saison" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <ComboBox fx:id="filterIntensiteCombo" prefWidth="130" promptText="Intensité" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 14;-fx-cursor:hand;-fx-font-size:14;" text="↺" />
                </HBox>

                <!-- Stats -->
                <HBox spacing="16">
                    <VBox spacing="4" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-border-left-width:4;-fx-border-color:#ff6b00 transparent transparent transparent;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="CATÉGORIES TOTALES" />
                        <Label fx:id="lblTotalCategories" style="-fx-font-size:44;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="0" />
                    </VBox>

                    <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="CATÉGORIE POPULAIRE" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size:22;" text="🏆" />
                            <VBox spacing="2">
                                <Label fx:id="lblTopCategorie" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;" text="—" />
                                <Label fx:id="lblTopType" style="-fx-text-fill:#888;-fx-font-size:12;" text="—" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="SAISON DOMINANTE" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="lblSaisonIcon" style="-fx-font-size:26;" text="🌤" />
                            <VBox spacing="2">
                                <Label fx:id="lblTopSaison" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;" text="—" />
                                <Label fx:id="lblSaisonCount" style="-fx-text-fill:#888;-fx-font-size:12;" text="0 catégories" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="PUBLIC CIBLE" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size:22;" text="👥" />
                            <Label fx:id="lblTopPublic" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:15;" text="—" />
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Titre section -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Liste des Catégories" />
                    <Label style="-fx-text-fill:#999;-fx-font-size:12;" text="— cliquez sur une carte pour explorer ses activités" />
                </HBox>

                <!-- Grille -->
                <ScrollPane fitToWidth="true" style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="categoriesGrid" hgap="16" style="-fx-padding:4 4 20 4;" vgap="16" />
                </ScrollPane>
            </VBox>

            <!-- ── Panneau droit ── -->
            <VBox prefWidth="300" spacing="20" style="-fx-padding:0 0 0 24;">

                <!-- PieChart Saison -->
                <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Répartition par Saison" />
                    <PieChart fx:id="pieChartSaison" labelsVisible="false" legendVisible="true" prefHeight="170" prefWidth="260" style="-fx-background-color:transparent;" />
                </VBox>

                <!-- PieChart Type -->
                <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Répartition par Type" />
                    <PieChart fx:id="pieChartType" labelsVisible="false" legendVisible="true" prefHeight="170" prefWidth="260" style="-fx-background-color:transparent;" />
                </VBox>

                <!-- Détail catégorie sélectionnée (lecture seule) -->
                <VBox spacing="10" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#888;" text="Catégorie sélectionnée" />
                    <Label fx:id="lblSelectedNom" style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="—" />
                    <Label fx:id="lblSelectedInfo" style="-fx-text-fill:#888;-fx-font-size:12;" text="Cliquez sur une carte" />
                    <Label style="-fx-text-fill:#aaa;-fx-font-size:11;" text="ℹ Cliquez sur une carte pour voir le détail." />
                </VBox>

                <!-- Reset filtres -->
                <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 20;-fx-cursor:hand;-fx-font-size:12;-fx-max-width:Infinity;" text="↺ Réinitialiser les filtres" />
            </VBox>
        </HBox>
    </center>

    <!-- Barre de bas -->
    <bottom>
        <Rectangle fill="linear-gradient(to right,#f5a623,#ff6b00,#6366f1)" height="5" width="1400" xmlns="http://javafx.com/javafx/22" />
    </bottom>

</BorderPane>
