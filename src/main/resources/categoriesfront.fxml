<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color:#f0f4f0;" stylesheets="@categoriesfront.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.CATfront">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- NAVBAR ORANGE - STYLE MATCHING DESTINATIONFRONT           -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color:#f5a623;-fx-padding:0 20;-fx-min-height:60;-fx-pref-height:60;">

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding:0 15 0 0;">
                    <Circle fill="#ff6b00" radius="14" />
                    <Label style="-fx-font-family: 'Segoe UI', Arial, sans-serif; -fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="TravelMate" />
                    <Label style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:8;-fx-padding:2 6;-fx-font-size:8;-fx-font-weight:bold;" text="PRO" />
                </HBox>

                <!-- Navigation links - espacement réduit (matching DestinationFront) -->
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="4" style="-fx-padding:6 10;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="🌍" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:500;-fx-font-size:12;" text="Destinations" />
                    </HBox>

                    <!-- Hébergements -->
                    <HBox fx:id="btnHebergements" alignment="CENTER" spacing="4" style="-fx-padding:6 10;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="🏨" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:500;-fx-font-size:12;" text="Hébergements" />
                    </HBox>

                    <!-- Itinéraires (kept for now but can be hidden via controller) -->
                    <HBox fx:id="btnItineraires" alignment="CENTER" spacing="4" style="-fx-padding:6 10;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="🗺" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:500;-fx-font-size:12;" text="Itinéraires" />
                    </HBox>

                    <!-- Catégories - ACTIVE (white background like Destinations in DestinationFront) -->
                    <HBox fx:id="btnCategories" alignment="CENTER" spacing="4" style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:6 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="📑" />
                        <Label style="-fx-text-fill:#ff6b00;-fx-font-weight:bold;-fx-font-size:12;" text="Catégories" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="4" style="-fx-padding:6 10;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="🏄" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:500;-fx-font-size:12;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="4" style="-fx-padding:6 10;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="✈" />
                        <Label style="-fx-text-fill:#1a1a1a;-fx-font-weight:500;-fx-font-size:12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets (orange background like in DestinationFront) -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="4" style="-fx-background-color:#ff6b00;-fx-background-radius:20;-fx-padding:6 14;-fx-cursor:hand;">
                        <Label style="-fx-font-size:12;" text="💰" />
                        <Label style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search Bar compacte (matching DestinationFront) -->
                <HBox alignment="CENTER" spacing="6" style="-fx-background-color:white;-fx-background-radius:20;-fx-padding:6 12;-fx-min-width:160;">
                    <Label style="-fx-font-size:12;-fx-text-fill:#999;" text="🔍" />
                    <TextField fx:id="searchField" prefWidth="130" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: #1a1a1a; -fx-prompt-text-fill: #aaa; -fx-border-color: transparent; -fx-font-size: 11;" />
                </HBox>

                <!-- Notifications -->
                <HBox alignment="CENTER" style="-fx-padding:0 5;">
                    <Label style="-fx-font-size:15;-fx-text-fill:#1a1a1a;-fx-cursor:hand;" text="🔔" />
                </HBox>

                <!-- User Profile compact (matching DestinationFront) -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="6" style="-fx-padding:4 0;-fx-cursor:hand;">
                    <Circle fill="#ff6b00" radius="14" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:11;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill:#5a3a00;-fx-font-size:9;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill:#333;-fx-font-size:10;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb compact (matching DestinationFront) -->
            <HBox alignment="CENTER_LEFT" spacing="5" style="-fx-background-color:#f0f4f0;-fx-padding:8 20;">
                <HBox fx:id="btnHome" alignment="CENTER" style="-fx-cursor:hand;">
                    <Label style="-fx-text-fill:#888;-fx-font-size:11;" text="🏠 Accueil" />
                </HBox>
                <Label style="-fx-text-fill:#aaa;-fx-font-size:11;" text="›" />
                <Label style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:3 10;-fx-font-size:11;" text="Catégories" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblDate" style="-fx-text-fill:#888;-fx-font-size:11;" text="📅 Mars 2026" />
                <HBox spacing="5">
                    <Button fx:id="btnTranslate" onAction="#handleTranslate" style="-fx-background-color:#10b981;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:4 12;-fx-font-size:11;-fx-cursor:hand;-fx-border-width:0;" text="🌐 Traduire" />
                    <Button fx:id="btnBackOffice" onAction="#handleToggleOffice" style="-fx-background-color:#6366f1;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:4 12;-fx-font-size:11;-fx-cursor:hand;-fx-border-width:0;" text="⚙ Back Office" />
                    <HBox fx:id="btnRefresh" alignment="CENTER" style="-fx-background-color:#f1f5f9;-fx-background-radius:10;-fx-min-width:32;-fx-min-height:32;-fx-cursor:hand;">
                        <Label style="-fx-font-size:16;-fx-text-fill:#475569;" text="🔄" />
                    </HBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- REST OF CONTENT (unchanged) -->
    <center>
        <VBox spacing="20" style="-fx-background-color:#f0f4f0;-fx-padding:20 30;">

            <!-- BOUTON COLORÉ EN HAUT À DROITE -->
            <HBox alignment="CENTER_RIGHT" style="-fx-padding:0 0 10 0;">
                <Button fx:id="btnVoirActivites" onAction="#navigateToActivites"
                        style="-fx-background-color: linear-gradient(to right, #ff6b00, #f5a623); -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: 500; -fx-background-radius: 25; -fx-padding: 6 16; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(255,107,0,0.3), 8, 0, 0, 2); -fx-border-width: 0;">
                    <graphic>
                        <HBox alignment="CENTER" spacing="6">
                            <Label style="-fx-font-size: 14; -fx-text-fill: white;" text="🎯" />
                            <Label style="-fx-font-size: 13; -fx-text-fill: white; -fx-font-weight: 500;" text="Voir les activités" />
                            <Label style="-fx-font-size: 14; -fx-text-fill: white;" text="→" />
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <!-- RESTE DU CONTENU (inchangé) -->
            <HBox spacing="0">
                <!-- Panneau gauche -->
                <VBox spacing="20" HBox.hgrow="ALWAYS">
                    <!-- Header + filtres -->
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:18 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label style="-fx-font-size:22;-fx-text-fill:#ff6b00;" text="📑" />
                        <Label style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Explorez les Catégories" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="filterTypeCombo" prefWidth="130" promptText="Type" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                        <ComboBox fx:id="filterSaisonCombo" prefWidth="140" promptText="Saison" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                        <ComboBox fx:id="filterIntensiteCombo" prefWidth="130" promptText="Intensité" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                        <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 14;-fx-cursor:hand;-fx-font-size:14;" text="↺" />
                    </HBox>

                    <!-- Stats -->
                    <HBox spacing="16">
                        <VBox spacing="4" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-border-left-width:4;-fx-border-color:#ff6b00 transparent transparent transparent;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="CATÉGORIES TOTALES" />
                            <Label fx:id="lblTotalCategories" style="-fx-font-size:44;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="0" />
                        </VBox>

                        <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="CATÉGORIE POPULAIRE" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:22;" text="🏆" />
                                <VBox spacing="2">
                                    <Label fx:id="lblTopCategorie" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;" text="—" />
                                    <Label fx:id="lblTopType" style="-fx-text-fill:#888;-fx-font-size:12;" text="—" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="SAISON DOMINANTE" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="lblSaisonIcon" style="-fx-font-size:26;" text="🌤" />
                                <VBox spacing="2">
                                    <Label fx:id="lblTopSaison" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:16;" text="—" />
                                    <Label fx:id="lblSaisonCount" style="-fx-text-fill:#888;-fx-font-size:12;" text="0 catégories" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="PUBLIC CIBLE" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label style="-fx-font-size:22;" text="👥" />
                                <Label fx:id="lblTopPublic" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:15;" text="—" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Titre section -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Liste des Catégories" />
                        <Label style="-fx-text-fill:#999;-fx-font-size:12;" text="— cliquez sur une carte pour explorer ses activités" />
                    </HBox>

                    <!-- Grille -->
                    <ScrollPane fitToWidth="true" style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;" VBox.vgrow="ALWAYS">
                        <GridPane fx:id="categoriesGrid" hgap="16" vgap="16">
                            <padding>
                                <Insets bottom="20" left="4" right="4" top="4" />
                            </padding>
                        </GridPane>
                    </ScrollPane>
                </VBox>

                <!-- Panneau droit -->
                <VBox prefWidth="360" spacing="20" style="-fx-padding:0 0 0 24;">
                    <!-- PieChart Saison -->
                    <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                        <Label style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Répartition par Saison" />
                        <PieChart fx:id="pieChartSaison" labelsVisible="true" legendVisible="true" prefHeight="200" prefWidth="280" style="-fx-background-color:transparent;" />
                    </VBox>

                    <!-- PieChart Type -->
                    <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20 20 30 20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                        <Label style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Répartition par Type" />
                        <PieChart fx:id="pieChartType" labelsVisible="true" legendVisible="true" prefHeight="220" prefWidth="280" style="-fx-background-color:transparent;" />
                    </VBox>

                    <!-- Détail catégorie sélectionnée -->
                    <VBox spacing="10" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                        <Label style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#888;" text="Catégorie sélectionnée" />
                        <Label fx:id="lblSelectedNom" style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="—" />
                        <Label fx:id="lblSelectedInfo" style="-fx-text-fill:#888;-fx-font-size:12;" text="Cliquez sur une carte" />
                        <Label style="-fx-text-fill:#aaa;-fx-font-size:11;" text="ℹ Cliquez sur une carte pour voir le détail." />
                    </VBox>

                    <!-- Reset filtres -->
                    <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 20;-fx-cursor:hand;-fx-font-size:12;-fx-max-width:Infinity;" text="↺ Réinitialiser les filtres" />
                </VBox>
            </HBox>
        </VBox>
    </center>

    <!-- Barre de bas -->
    <bottom>
        <Rectangle fill="linear-gradient(to right,#f5a623,#ff6b00,#6366f1)" height="5" width="1400" />
    </bottom>

</BorderPane>