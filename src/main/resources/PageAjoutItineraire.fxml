<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="600" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlles.PageAjoutItineraire">

    <!-- TOP NAV -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="15" left="24" right="24" top="15" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="8">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="12" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 8; -fx-font-size: 9; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU -->
                <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0 0 0 15;">
                    <!-- Destinations -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Destinations" />
                    </HBox>

                    <!-- Itinéraires - Active -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: rgba(255,140,66,0.1); -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label style="-fx-font-size: 14;" text="🗺️" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 12;" text="Itinéraires" />
                    </HBox>

                    <!-- Activités -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="🏄" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="✈️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox alignment="CENTER" spacing="6" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 6 12; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 14;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 12;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- User Profile -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 4 12 4 4; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="12" />
                    <VBox spacing="0">
                        <Label style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 11;" text="Meriem Bou" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 8;" text="Utilisateur" />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 8 24;">
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="🏠 Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="›" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Itinéraires" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 10; -fx-font-weight: 600;" text="Nouvel itinéraire" />
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT - FORMULAIRE -->
    <center>
        <VBox spacing="20" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8fafc;">
            <padding>
                <Insets bottom="30" left="24" right="24" top="24" />
            </padding>

            <!-- HEADER SECTION -->
            <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                <VBox alignment="CENTER" style="-fx-background-color: #fff7ed; -fx-background-radius: 18; -fx-min-width: 60; -fx-min-height: 60;">
                    <Label style="-fx-font-size: 36;" text="➕" />
                </VBox>

                <VBox spacing="6">
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Nouvel itinéraire" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Créez un nouvel itinéraire de voyage" />
                </VBox>
            </HBox>

            <!-- FORM CARD -->
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

                <!-- Nom de l'itinéraire -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Nom de l'itinéraire *" />
                    <Label style="-fx-text-fill: #ef4444; -fx-font-size: 10;" text="(maximum 10 caractères)" />
                    <TextField fx:id="nomField" promptText="Ex: Paris 2024" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />
                </VBox>

                <!-- Description -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Description" />
                    <TextArea fx:id="descriptionField" promptText="Décrivez votre itinéraire..." prefRowCount="4" wrapText="true" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8;" />
                </VBox>

                <!-- Voyage associé -->
                <VBox spacing="8">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a; -fx-font-size: 13;" text="Voyage associé *" />
                    <ComboBox fx:id="voyageCombo" promptText="Sélectionner un voyage" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 4;" HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="Choisissez le voyage auquel cet itinéraire appartient" />
                </VBox>

                <!-- Message d'erreur (caché par défaut) -->
                <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11;" managed="false" visible="false" wrapText="true" />

                <!-- Boutons d'action -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button onAction="#handleAnnuler" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Annuler" />
                    <Button onAction="#handleCreer" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;" text="Créer l'itinéraire" />
                </HBox>
            </VBox>

            <!-- BOTTOM DECORATION -->
            <Rectangle arcHeight="6" arcWidth="6" fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="3" />
        </VBox>
    </center>
</BorderPane>