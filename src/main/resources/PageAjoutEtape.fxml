<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlles.PageAjoutEtape"
            prefWidth="500"
            style="-fx-background-color: white; -fx-background-radius: 10;">

    <content>
        <VBox spacing="15" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>

            <!-- Titre -->
            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;"
                   text="Ajouter une étape" />

            <!-- Heure -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Heure *" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Spinner fx:id="heureSpinner" prefWidth="80" />
                    <Label text=":" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                    <Spinner fx:id="minuteSpinner" prefWidth="80" />
                </HBox>
            </VBox>

            <!-- Lieu -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Lieu *" />
                <TextField fx:id="lieuField" promptText="Ex: Centre ville, Musée..."
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 5; -fx-padding: 8;" />
            </VBox>

            <!-- Activité -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Activité *" />
                <ComboBox fx:id="activiteCombo" promptText="Sélectionner une activité"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 5; -fx-padding: 4;" />
            </VBox>

            <!-- Description -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: 600; -fx-text-fill: #0f172a;" text="Description" />
                <TextArea fx:id="descriptionField" promptText="Détails de l'étape..."
                          prefRowCount="3" wrapText="true"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 5;" />
            </VBox>

            <!-- Message d'erreur -->
            <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11;"
                   managed="false" visible="false" wrapText="true" />
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="CANCEL" text="Annuler" />
        <ButtonType fx:constant="OK" text="Ajouter" />
    </buttonTypes>

</DialogPane>