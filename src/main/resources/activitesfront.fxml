<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.geometry.Insets?>
<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #f0f4f0;" stylesheets="@activitesfront.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ACTfront">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- NAVBAR ORANGE - IDENTICAL TO DESTINATIONFRONT             -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <!-- Main Navigation Bar - Style identique à DestinationFront -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 2);">
                <padding>
                    <Insets bottom="20" left="32" right="32" top="20" />
                </padding>

                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <!-- MAIN NAVIGATION MENU -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 0 20;">
                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🌍" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Destinations" />
                    </HBox>

                    <!-- Hébergements -->
                    <HBox fx:id="btnHebergements" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🏨" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergements" />
                    </HBox>

                    <!-- Catégories (btnVersCategories) -->
                    <HBox fx:id="btnVersCategories" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="📑" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Catégories" />
                    </HBox>

                    <!-- Activités - ACTIVE -->
                    <HBox fx:id="btnActivites" alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,140,66,0.1); -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 16;" text="🏄" />
                        <Label style="-fx-text-fill: #ff8c42; -fx-font-weight: 600; -fx-font-size: 14;" text="Activités" />
                    </HBox>

                    <!-- Voyages -->
                    <HBox fx:id="btnVoyages" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="✈️" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Voyages" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER" spacing="8" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 8 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="💰" />
                        <Label style="-fx-text-fill: #475569; -fx-font-weight: 500; -fx-font-size: 14;" text="Budgets" />
                    </HBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications with badge -->
                <StackPane>
                    <HBox fx:id="btnNotifications" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16;" text="🔔" />
                    </HBox>
                    <Label fx:id="lblNotificationBadge" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 18; -fx-min-height: 18; -fx-alignment: center; -fx-font-size: 10; -fx-font-weight: bold; -fx-translate-x: 12; -fx-translate-y: -12;" text="0" visible="false" />
                </StackPane>

                <!-- User Profile -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #f1f5f9; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #0f172a; -fx-font-weight: 600; -fx-font-size: 13;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="..." />
                    </VBox>
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="▼" />
                </HBox>
            </HBox>

            <!-- Breadcrumb Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 12 32;">
                <!-- Home Button -->
                <HBox fx:id="btnHome" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="🏠" />
                </HBox>
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Accueil" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 12;" text="Activités" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="›" />
                <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 12; -fx-font-weight: 600;" text="Explorer les activités" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Refresh Button -->
                <HBox spacing="8">
                    <Button fx:id="btnTranslate" onAction="#handleTranslate" style="-fx-background-color:#10b981;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:4 12;-fx-font-size:11;-fx-cursor:hand;-fx-border-width:0;" text="🌐 Traduire" />
                    <Button fx:id="btnBackOffice" onAction="#handleBackOffice" style="-fx-background-color:#6366f1;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:4 12;-fx-font-size:11;-fx-cursor:hand;-fx-border-width:0;" text="⚙ Back Office" />
                    <HBox fx:id="btnRefresh" alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 18; -fx-text-fill: #475569;" text="🔄" />
                    </HBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- RESTE DU CONTENU (unchanged) -->
    <center>
        <HBox spacing="0" style="-fx-background-color:#f0f4f0;-fx-padding:20 30;">
            <!-- Panneau gauche -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <!-- Header + filtres -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:18 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label style="-fx-font-size:22;-fx-text-fill:#ff6b00;" text="🎯" />
                    <Label fx:id="titleLabel" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Explorez les Activités" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="filterTypeCombo" prefWidth="130" promptText="Type" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <ComboBox fx:id="filterSaisonCombo" prefWidth="140" promptText="Saison" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <ComboBox fx:id="filterDifficulteCombo" prefWidth="130" promptText="Difficulté" style="-fx-background-color:white;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;" />
                    <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 14;-fx-cursor:hand;-fx-font-size:14;" text="↺" />
                </HBox>

                <!-- Stats -->
                <HBox spacing="16">
                    <VBox spacing="4" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-border-left-width:4;-fx-border-color:#ff6b00 transparent transparent transparent;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="ACTIVITÉS TOTALES" />
                        <Label fx:id="lblTotalActivites" style="-fx-font-size:44;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="0" />
                    </VBox>

                    <VBox spacing="6" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="BUDGET MOYEN" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size:22;" text="📋" />
                            <VBox spacing="2">
                                <Label fx:id="lblDateMoyenne" style="-fx-text-fill:#888;-fx-font-size:12;" text="—" />
                                <Label fx:id="lblNomMoyenne" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:14;" text="—" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:20 24;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill:#999;-fx-font-size:11;-fx-font-weight:bold;" text="TOP ACTIVITÉ" />
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size:13;" text="📋" />
                            <Label fx:id="lblTopLieu" style="-fx-text-fill:#1a1a1a;-fx-font-size:13;" text="—" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblTopBudget" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:13;" text="—" />
                        </HBox>
                        <ProgressBar fx:id="progressTop" maxWidth="240" prefHeight="6" progress="0.0" style="-fx-accent:#ff6b00;-fx-background-radius:3;" />
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size:13;" text="📍" />
                            <Label fx:id="lblTopNom" style="-fx-text-fill:#888;-fx-font-size:12;" text="—" />
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Titre section -->
                <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Liste des Expériences" />

                <!-- Grille -->
                <ScrollPane fitToWidth="true" style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="activitesGrid" hgap="16" style="-fx-padding:4 4 20 4;" vgap="16" />
                </ScrollPane>
            </VBox>

            <!-- Panneau droit -->
            <VBox prefWidth="300" spacing="20" style="-fx-padding:0 0 0 24;">
                <!-- PieChart -->
                <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="Répartition par Type" />
                    <PieChart fx:id="pieChart" labelsVisible="true" legendVisible="true" prefHeight="280" prefWidth="320" style="-fx-background-color:transparent;" />
                </VBox>

                <!-- Détail activité sélectionnée -->
                <VBox spacing="10" style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:20;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.08),10,0,0,2);">
                    <Label style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#888;" text="Activité sélectionnée" />
                    <Label fx:id="lblSelectedNom" style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;" text="—" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle fx:id="dotColor" fill="#ff6b00" radius="7" />
                        <Label fx:id="lblSelectedDate" style="-fx-text-fill:#666;-fx-font-size:13;" text="—" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblSelectedBudget" style="-fx-text-fill:#1a1a1a;-fx-font-weight:bold;-fx-font-size:13;" text="—" />
                    </HBox>
                    <Label style="-fx-text-fill:#aaa;-fx-font-size:11;-fx-wrap-text:true;" text="ℹ Cliquez sur une activité pour voir son détail." />
                </VBox>

                <!-- Lien vers catégories -->
                <VBox spacing="8" style="-fx-background-color:white;-fx-background-radius:12;-fx-padding:16;-fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#888;" text="Explorer par catégorie" />
                    <HBox alignment="CENTER_LEFT" onMouseClicked="#handleVersCategories" spacing="8" style="-fx-cursor:hand;-fx-background-color:#fff3e8;-fx-background-radius:10;-fx-padding:10;">
                        <Label style="-fx-font-size:16;" text="📑" />
                        <Label style="-fx-text-fill:#ff6b00;-fx-font-weight:bold;-fx-font-size:13;" text="Voir toutes les Catégories" />
                    </HBox>
                </VBox>

                <!-- Reset filtres -->
                <Button onAction="#handleResetFilters" style="-fx-background-color:white;-fx-text-fill:#888;-fx-border-color:#ddd;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 20;-fx-cursor:hand;-fx-font-size:12;-fx-max-width:Infinity;" text="↺ Réinitialiser les filtres" />

                <!-- Bouton pour revenir à toutes les activités -->
                <Button fx:id="btnAllActivities" onAction="#handleShowAllActivities" visible="false" managed="false" style="-fx-background-color:#ff6b00;-fx-text-fill:white;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 20;-fx-cursor:hand;-fx-font-size:12;-fx-max-width:Infinity;-fx-font-weight:bold;" text="← Voir toutes les activités" />
            </VBox>
        </HBox>
    </center>

    <!-- Barre de bas subtile -->
    <bottom>
        <Rectangle fill="linear-gradient(to right, rgba(245,166,35,0.5), rgba(255,107,0,0.5), rgba(99,102,241,0.5))" height="3" width="1400" />
    </bottom>

</BorderPane>