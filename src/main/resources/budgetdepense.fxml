                    <!-- ORANGE ACCENT BOTTOM DECORATION -->
                    <Rectangle fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="4" width="1200" arcHeight="8" arcWidth="8">
                        <VBox.margin>
                            <Insets top="20" />
                        </VBox.margin>
                    </Rectangle>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>