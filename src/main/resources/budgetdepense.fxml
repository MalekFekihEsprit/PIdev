                        <!-- TABLE with orange selection -->
                        <TableView fx:id="tableDepenses" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 20;" VBox.vgrow="ALWAYS">
