                            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 12; -fx-padding: 10 14;">
                                <Label style="-fx-text-fill: white; -fx-font-size: 12;" text="🔒" />
                                <Label style="-fx-text-fill: white; -fx-font-weight: 500; -fx-font-size: 12;" text="Données protégées" />
                            </HBox>
                        </VBox>
