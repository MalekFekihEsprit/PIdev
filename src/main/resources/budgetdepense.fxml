                                </HBox>
                                <HBox alignment="CENTER" spacing="6">
                                    <Circle fill="#34d399" radius="6" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Restant" />
                                </HBox>
                            </HBox>
                        </VBox>

                        <!-- Info Card with orange gradient -->
                        <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #ff8c42, #ff6b4a); -fx-background-radius: 20; -fx-padding: 24;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40;">
                                    <Label style="-fx-font-size: 20;" text="💡" />
                                </VBox>
                                <Label style="-fx-font-weight: 700; -fx-text-fill: white; -fx-font-size: 14; -fx-letter-spacing: 1;" text="INFORMATION" />
