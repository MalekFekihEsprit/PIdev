                                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 14;" text="Aucune dépense à afficher" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- STATISTICS SECTION with orange accent -->
                    <HBox spacing="20">
                        <!-- Répartition Card with orange accent -->
                        <VBox spacing="16" style="-fx-background-color: #1e2749; -fx-background-radius: 20; -fx-padding: 24; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: 600; -fx-text-fill: #ffffff; -fx-font-size: 16;" text="Répartition du Budget" />
                            <HBox alignment="CENTER" spacing="32">
                                <VBox alignment="CENTER" spacing="8">
                                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #f87171;" text="65%" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" text="Utilisé" />
                                </VBox>
                                <Rectangle fill="#2d3a5f" height="80" width="1" />
                                <VBox alignment="CENTER" spacing="8">
                                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #34d399;" text="35%" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" text="Disponible" />
