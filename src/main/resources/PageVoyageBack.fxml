<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="900" prefWidth="1400" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.VoyageBackController">

    <!-- TOP NAV - DARK MODE WITH ORANGE ACCENT (identique à DestinationBack) -->
    <top>
        <VBox>
            <!-- Main Navigation Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0;">
                <padding><Insets bottom="20" left="32" right="32" top="20" /></padding>

                <HBox alignment="CENTER" spacing="10">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="TravelMate" />
                    <Label style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 4 10; -fx-font-size: 10; -fx-font-weight: bold;" text="PRO" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notifications with badge -->
                <HBox alignment="CENTER" style="-fx-background-color: #1e2749; -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16;" text="🔔" />
                    <Circle fill="#ff8c42" radius="6" translateX="10" translateY="-10" />
                </HBox>

                <!-- User Profile - CLICKABLE -->
                <HBox fx:id="userProfileBox" alignment="CENTER" spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 25; -fx-padding: 6 16 6 6; -fx-cursor: hand;">
                    <Circle fill="linear-gradient(from 0% 0% to 100% 100%, #ff8c42, #ff6b4a)" radius="16" />
                    <VBox spacing="0">
                        <Label fx:id="lblUserName" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 13;" text="Chargement..." />
                        <Label fx:id="lblUserRole" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="..." />
                    </VBox>
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="▼" />
                </HBox>
            </HBox>

            <!-- Secondary Navigation - Quick Filters -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #0a0e27; -fx-border-color: #1e2749; -fx-border-width: 0 0 1 0; -fx-padding: 8 32;">
                <HBox alignment="CENTER" spacing="8">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12; -fx-font-weight: 500;" text="FILTRES RAPIDES :" />
                    <Label style="-fx-background-color: #1e2749; -fx-text-fill: #94a3b8; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Tous" />
                    <Label style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="À venir" />
                    <Label style="-fx-background-color: rgba(16,185,129,0.15); -fx-text-fill: #10b981; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="En cours" />
                    <Label style="-fx-background-color: rgba(239,68,68,0.15); -fx-text-fill: #ef4444; -fx-background-radius: 16; -fx-padding: 4 12; -fx-font-size: 11; -fx-cursor: hand;" text="Terminé" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <!-- SIDEBAR - MENU ADMINISTRATION (identique à DestinationBack) -->
    <left>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: #111633; -fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 0 1 0 0;">
            <VBox prefWidth="280" spacing="8" style="-fx-background-color: #111633;">
                <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>

                <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #64748b; -fx-letter-spacing: 1.5;" text="DASHBOARD" />

                <VBox spacing="4">
                    <padding><Insets top="12" /></padding>



                    <!-- Destinations -->
                    <HBox fx:id="btnDestinations" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleDestinationsClick">
                        <Label style="-fx-font-size: 16;" text="🌍" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Destinations" />
                    </HBox>

                    <!-- Hébergement -->
                    <HBox fx:id="btnHebergement" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleHebergementClick">
                        <Label style="-fx-font-size: 16;" text="🏨" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Hébergement" />
                    </HBox>


                    <!-- Utilisateurs -->
                    <HBox fx:id="btnUsers" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleUsersClick">
                        <Label style="-fx-font-size: 16;" text="👥" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Utilisateurs" />
                    </HBox>

                    <!-- Statistiques -->
                    <HBox fx:id="btnStats" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleStatsClick">
                        <Label style="-fx-font-size: 16;" text="📊" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Statistiques" />
                    </HBox>

                    <!-- Activités -->
                    <HBox fx:id="btnActivites" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleActivitesClick">
                        <Label style="-fx-font-size: 16;" text="🏄" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Activités" />
                    </HBox>

                    <!-- Catégories -->
                    <HBox fx:id="btnCategories" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleCategoriesClick">
                        <Label style="-fx-font-size: 16;" text="📑" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Catégories" />
                    </HBox>

                    <!-- Voyages - ACTIF -->
                    <HBox fx:id="btnVoyages" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: linear-gradient(to right, #ff8c42, #ff6b4a); -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;">
                        <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="✈️" />
                        <Label style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 14;" text="Voyages" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblSidebarVoyagesCount" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10; -fx-padding: 2 8; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="0" />
                    </HBox>

                    <!-- Budgets -->
                    <HBox fx:id="btnBudgets" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 12 16; -fx-cursor: hand;" onMouseClicked="#handleBudgetsClick">
                        <Label style="-fx-font-size: 16;" text="💰" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-weight: 500; -fx-font-size: 14;" text="Budgets" />
                    </HBox>




                </VBox>

                <!-- DIVIDER -->
                <Rectangle fill="#1e2749" height="1" width="240"><VBox.margin><Insets bottom="12" top="12" /></VBox.margin></Rectangle>

                <!-- STATS RAPIDES -->
                <VBox spacing="12" style="-fx-background-color: #0a0e27; -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #1e2749; -fx-border-width: 1; -fx-border-radius: 16;">
                    <Label style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 11; -fx-letter-spacing: 1;" text="STATISTIQUES GLOBALES" />
                    <GridPane hgap="10" vgap="10">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Total voyages:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="statsTotalVoyages" style="-fx-font-weight: bold; -fx-text-fill: #ff8c42; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Actifs:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="statsActifs" style="-fx-font-weight: bold; -fx-text-fill: #10b981; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Terminés:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="statsTermines" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 12;" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <columnConstraints><ColumnConstraints /><ColumnConstraints halignment="RIGHT" /></columnConstraints>
                        <rowConstraints><RowConstraints /><RowConstraints /><RowConstraints /></rowConstraints>
                    </GridPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </left>

    <!-- BOTTOM STATUS (identique à DestinationBack) -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #111633; -fx-border-color: #1e2749; -fx-border-width: 1 0 0 0; -fx-padding: 10 28;">
            <Label style="-fx-text-fill: #ff8c42; -fx-font-size: 11; -fx-font-weight: 500;" text="● Connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblLastUpdate" style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Dernière mise à jour: 12 Fév 2026, 15:30" />
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="©️ 2026 TravelMate" />
        </HBox>
    </bottom>

    <!-- MAIN CONTENT (contenu original conservé) -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #0a0e27; -fx-border-color: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="30" left="20" right="20" top="15" />
                    </padding>

                    <!-- HEADER SECTION -->
                    <VBox spacing="4">
                        <Label style="-fx-font-family: 'Clash Display'; -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Gestion des Voyages" />
                        <HBox spacing="5">
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11;" text="Administration complète" />
                            <Label style="-fx-background-color: rgba(255,140,66,0.15); -fx-text-fill: #ff8c42; -fx-background-radius: 12; -fx-padding: 1 8; -fx-font-size: 9;" text="● Mode édition" />
                        </HBox>
                    </VBox>

                    <!-- STATS CARDS (stylisées comme DestinationBack) -->
                    <HBox spacing="10">
                        <!-- Total Voyages Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(255,140,66,0.15); -fx-background-radius: 8; -fx-min-width: 30; -fx-min-height: 30;">
                                    <Label style="-fx-font-size: 16;" text="✈️" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 9; -fx-font-weight: 500;" text="TOTAL" />
                                    <Label fx:id="lblTotalVoyages" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Voyages Actifs Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #10b981; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(16,185,129,0.15); -fx-background-radius: 8; -fx-min-width: 30; -fx-min-height: 30;">
                                    <Label style="-fx-font-size: 16;" text="🟢" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 9; -fx-font-weight: 500;" text="ACTIFS" />
                                    <Label fx:id="lblVoyagesActifs" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Voyages Terminés Card -->
                        <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #1e2749, #111633); -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #64748b; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <VBox alignment="CENTER" style="-fx-background-color: rgba(100,116,139,0.15); -fx-background-radius: 8; -fx-min-width: 30; -fx-min-height: 30;">
                                    <Label style="-fx-font-size: 16;" text="✅" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 9; -fx-font-weight: 500;" text="TERMINÉS" />
                                    <Label fx:id="lblVoyagesTermines" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- STATISTIQUES AVANCÉES ET EXPORT (contenu original) -->
                    <HBox spacing="15">
                        <!-- Carte des statistiques par statut -->
                        <VBox spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="📊 Statistiques par statut" />

                            <HBox spacing="20" alignment="CENTER">
                                <!-- Pie Chart -->
                                <PieChart fx:id="pieChartStatuts" prefWidth="200" prefHeight="200"
                                          style="-fx-background-color: transparent;"
                                          labelsVisible="true" legendVisible="false"
                                          animated="true" startAngle="90" />

                                <!-- Légende personnalisée avec pourcentages -->
                                <VBox spacing="8" alignment="CENTER_LEFT">
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Rectangle fill="#ff8c42" width="12" height="12" arcHeight="4" arcWidth="4" />
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="À venir:" />
                                        <Label fx:id="lblCountAVenir" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 11;" text="0" />
                                        <Label fx:id="lblPourcentAVenir" style="-fx-text-fill: #ff8c42; -fx-font-size: 10;" text="(0%)" />
                                    </HBox>

                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Rectangle fill="#10b981" width="12" height="12" arcHeight="4" arcWidth="4" />
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="En cours:" />
                                        <Label fx:id="lblCountEnCours" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 11;" text="0" />
                                        <Label fx:id="lblPourcentEnCours" style="-fx-text-fill: #10b981; -fx-font-size: 10;" text="(0%)" />
                                    </HBox>

                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Rectangle fill="#64748b" width="12" height="12" arcHeight="4" arcWidth="4" />
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Terminé:" />
                                        <Label fx:id="lblCountTermine" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 11;" text="0" />
                                        <Label fx:id="lblPourcentTermine" style="-fx-text-fill: #64748b; -fx-font-size: 10;" text="(0%)" />
                                    </HBox>

                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Rectangle fill="#ec4899" width="12" height="12" arcHeight="4" arcWidth="4" />
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Annulé:" />
                                        <Label fx:id="lblCountAnnule" style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-size: 11;" text="0" />
                                        <Label fx:id="lblPourcentAnnule" style="-fx-text-fill: #ec4899; -fx-font-size: 10;" text="(0%)" />
                                    </HBox>

                                    <Separator style="-fx-background-color: #0a0e27;" />

                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Total:" />
                                        <Label fx:id="lblTotalVoyages2" style="-fx-text-fill: #ffffff; -fx-font-weight: 700; -fx-font-size: 14;" text="0" />
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Carte des actions d'export -->
                        <VBox spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="📥 Export des données" />

                            <VBox spacing="8" alignment="CENTER">
                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11; -fx-wrap-text: true;"
                                       text="Exporter la liste des voyages au format PDF ou Excel" />

                                <HBox spacing="10" alignment="CENTER">
                                    <Button fx:id="btnExportPDF" style="-fx-background-color: #ec4899; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-size: 12; -fx-font-weight: 600; -fx-cursor: hand;" text="📄 Exporter PDF">
                                        <graphic>
                                            <Label style="-fx-font-size: 14;" text="📄" />
                                        </graphic>
                                    </Button>

                                    <Button fx:id="btnExportExcel" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-size: 12; -fx-font-weight: 600; -fx-cursor: hand;" text="📊 Exporter Excel">
                                        <graphic>
                                            <Label style="-fx-font-size: 14;" text="📊" />
                                        </graphic>
                                    </Button>
                                </HBox>

                                <Label style="-fx-text-fill: #64748b; -fx-font-size: 9; -fx-padding: 10 0 0 0;"
                                       text="Les fichiers seront sauvegardés dans le dossier 'exports'" />
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- RECHERCHE AVANCÉE (contenu original) -->
                    <VBox spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="🔍 Recherche avancée" />

                        <GridPane hgap="10" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="15" />
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="15" />
                                <ColumnConstraints percentWidth="35" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>

                            <!-- Recherche par titre -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Titre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="tfSearchTitre" promptText="Rechercher par titre..." style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <!-- Recherche par ID -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="ID:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <TextField fx:id="tfSearchId" promptText="ID exact" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                            <!-- Recherche par statut -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <ComboBox fx:id="cbSearchStatut" prefWidth="150" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <!-- Boutons de recherche -->
                            <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                <Button fx:id="btnSearch" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="🔍 Rechercher" />
                                <Button fx:id="btnReset" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="🔄 Réinitialiser" />
                            </HBox>
                        </GridPane>

                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 9;" text="Cliquez sur les en-têtes de colonnes pour trier par date (début/fin)" />
                    </VBox>

                    <!-- FORMULAIRE D'AJOUT/MODIFICATION (contenu original) -->
                    <VBox spacing="10" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="✏️ Formulaire Voyage" />

                        <GridPane hgap="10" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="20" />
                                <ColumnConstraints percentWidth="30" />
                                <ColumnConstraints percentWidth="20" />
                                <ColumnConstraints percentWidth="30" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>

                            <!-- Titre -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Titre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="tfTitre" promptText="Titre du voyage" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <!-- Statut -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Statut:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <ComboBox fx:id="cbStatut" promptText="Statut" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                            <!-- Date début -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Début:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <DatePicker fx:id="dpDateDebut" promptText="JJ/MM/AAAA" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <!-- Date fin -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Fin:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                            <DatePicker fx:id="dpDateFin" promptText="JJ/MM/AAAA" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6;" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                            <!-- ID Destination -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="ID Dest:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <TextField fx:id="tfIdDestination" promptText="ID" style="-fx-background-color: #0a0e27; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                            <!-- Nom Destination -->
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="Destination:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                            <TextField fx:id="tfDestinationNom" editable="false" style="-fx-background-color: #0a0e27; -fx-text-fill: #94a3b8; -fx-background-radius: 6; -fx-padding: 6;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                        </GridPane>

                        <!-- Boutons d'action -->
                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Button fx:id="btnAjouter" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="➕ Ajouter" />
                            <Button fx:id="btnModifier" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="✏️ Modifier" />
                            <Button fx:id="btnAnnuler" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="❌ Annuler" />
                            <Button fx:id="btnRefresh" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 11; -fx-font-weight: 600;" text="🔄 Refresh" />
                        </HBox>
                    </VBox>

                    <!-- TABLE DES VOYAGES (contenu original) -->
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #ffffff;" text="Liste des Voyages" />
                            <Label fx:id="lblVoyagesCount" style="-fx-background-color: #ff8c42; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 2 8; -fx-font-size: 10;" text="0" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 9;" text="Trier : cliquer sur les colonnes Date début / Date fin" />
                        </HBox>

                        <TableView fx:id="tableVoyages" style="-fx-background-color: #1e2749; -fx-background-radius: 12; -fx-border-color: #ff8c42; -fx-border-width: 1; -fx-border-radius: 12;" prefHeight="300">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                                <TableColumn fx:id="colTitre" prefWidth="150" text="Titre" />
                                <TableColumn fx:id="colDateDebut" prefWidth="90" text="Début" sortable="true" />
                                <TableColumn fx:id="colDateFin" prefWidth="90" text="Fin" sortable="true" />
                                <TableColumn fx:id="colStatut" prefWidth="90" text="Statut" sortable="true" />
                                <TableColumn fx:id="colIdDestination" prefWidth="70" text="ID Dest" />
                                <TableColumn fx:id="colDestination" prefWidth="120" text="Destination" />
                                <TableColumn fx:id="colActions" prefWidth="200" text="Actions" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- BOTTOM DECORATION -->
                    <Rectangle fill="linear-gradient(to right, #ff8c42, #ff6b4a, #6366f1)" height="2" width="1000" arcHeight="4" arcWidth="4">
                        <VBox.margin>
                            <Insets top="10" />
                        </VBox.margin>
                    </Rectangle>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>